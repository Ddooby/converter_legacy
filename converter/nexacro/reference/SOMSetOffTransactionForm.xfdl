                    var issue_id_param = g_GetCourtPermitNoPopup3(team_code, due_date, me_postingDate.Value);
                    // CLOSE, X표시 이외의 경우,,
                    if( issue_id_param != null ){
                        if( issue_id_param[1] == 'C' ){  // cancel 버튼 클릭
                            OTCStlInvoDetailDS.SetColumn(cursorRowPos, "court_admit_no", "");
                            OTCStlInvoDetailDS.SetColumn(cursorRowPos, "court_flag", "");
                        }
                        if( !g_isEmpty(issue_id_param[0]) ){    // 법원허가번호 클릭
                            OTCStlInvoDetailDS.SetColumn(cursorRowPos, "court_admit_no", issue_id_param[0]);
                            OTCStlInvoDetailDS.SetColumn(cursorRowPos, "court_flag", issue_id_param[1]);
