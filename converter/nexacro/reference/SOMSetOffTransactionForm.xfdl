        }
        */
    }).call(this);
};

this.OTCStlHeadDS_OnColumnChanged = function(obj:nexacro.NormalDataset, e:nexacro.DSColChangeEventInfo)
{
	(async () => {
		if(e.columnid == "curcy_code") {
			this.currencyCol = e.newvalue;
			this.OTCStlSettleDetailDS.clearData(); // 이종화폐이면 Settle 검색되는 내역이 바뀌므로 모두 지우고 새로 조회케 함
			this.OTCStlInvoDetailDS.clearData();
			await this.fnGetExcRate();
			await this.fnSetDrCrAmt();
			await this.fnSetDiffAmt();
		} else if (e.columnid == "posting_date") {
			await this.fnGetExcRate();
			this.OTCStlInvoDetailDS.set_enableevent(false);
			for (var row = 0; row < this.OTCStlInvoDetailDS.rowcount; row++) {
				var stl_loc_amt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(row, "stl_loc_amt"), 0));
				this.OTCStlInvoDetailDS.setColumn(row, "stl_usd_amt", nexacro.round(stl_loc_amt.mul(this.usdLocExcRate), 2));
				this.OTCStlInvoDetailDS.setColumn(row, "stl_krw_amt", Math.trunc(stl_loc_amt.mul(this.locExcRate)));
			}
			this.OTCStlInvoDetailDS.set_enableevent(true);
			await this.fnSetDrCrAmt();
			await this.fnSetDiffAmt();
		}
	}).call(this);
};

this.OTCStlSettleDetailDS_OnColumnChanged = function(obj:nexacro.NormalDataset, e:nexacro.DSColChangeEventInfo)
{
	(async () => {
		if (e.columnid == "check_item") {
			this.OTCStlSettleDetailDS.set_enableevent(false);
			if(e.newvalue == "1") {
				this.OTCStlSettleDetailDS.setColumn(e.row, "stl_loc_amt", nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(e.row, "open_loc_amt"))));
				this.OTCStlSettleDetailDS.setColumn(e.row, "stl_usd_amt", nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(e.row, "open_usd_amt"))));
				this.OTCStlSettleDetailDS.setColumn(e.row, "stl_krw_amt", nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(e.row, "open_krw_amt"))));
			} else if(e.newvalue == "0") {
				this.OTCStlSettleDetailDS.setColumn(e.row, "stl_loc_amt", 0);
				this.OTCStlSettleDetailDS.setColumn(e.row, "stl_usd_amt", 0);
				this.OTCStlSettleDetailDS.setColumn(e.row, "stl_krw_amt", 0);
			}
			this.OTCStlSettleDetailDS.set_enableevent(true);
			await this.fnSetDrCrAmt();
			await this.fnSetDiffAmt();
		} else if (e.columnid == "stl_loc_amt" || e.columnid == "stl_usd_amt" || e.columnid == "stl_krw_amt" ) {
			this.OTCStlSettleDetailDS.set_enableevent(false);
			await this.fnSetStlComparisonRate(e.row);
			await this.fnSetSettleAmt(e.row);
			this.OTCStlSettleDetailDS.set_enableevent(true);
			await this.fnSetDrCrAmt();
			await this.fnSetDiffAmt();
		}
	}).call(this);
};

this.OTCStlInvoDetailDS_OnColumnChanged = function(obj:nexacro.NormalDataset, e:nexacro.DSColChangeEventInfo)
{
	(async () => {
		//------------------------------------------------------------------------------------------------------------------------
		// 일반관리비 은행수수료('630601') -> 고정비 은행수수료('540203') 으로 계정 변경 관련 (20160906 HIJANG)
		//------------------------------------------------------------------------------------------------------------------------
		if(e.columnid == "vsl_code" ) {
			if( e.newvalue != "0000" && e.newvalue != "000" && e.newvalue != "00" && e.newvalue != "0" ) {
				if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(e.row, "gl_acc_code")) ) {
					if( this.OTCStlInvoDetailDS.getColumn(e.row, "gl_acc_code") == "540203" ) {    // 고정비 은행수수료
						if( nexacro.toNumber(this.OTCStlInvoDetailDS.getColumn(e.row, "voy_no")) != 0 ) {
							// 해당 VSL-VOY 항차의 CB 상의 '영업팀' 가져오기 !!
							var cb_team_code = await com.fnGetVoyNoSalesTeamCode(this, take.nvl(this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code")), take.nvl(this.OTCStlInvoDetailDS.getColumn(e.row, "voy_no")));
							//alert("cb_team_code : " + cb_team_code);
							// VSL-VOY 의 CB 영업팀값 으로 세팅
							this.OTCStlInvoDetailDS.setColumn(e.row, "team_code", cb_team_code);
						} else {
							await com.fnMessageOpenForm(this, "E", "은행수수료(540203) 계정은 '0' 항차를 입력하실 수 없습니다.\n확인 바랍니다.");
							this.OTCStlInvoDetailDS.setColumn(e.row, "gl_acc_code","");
							this.OTCStlInvoDetailDS.setColumn(e.row, "team_code","");
							com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 1, e.row);
							return false;
						}
					}
				}
			} else {
				// 기존 입력값 Clear..
				this.OTCStlInvoDetailDS.setColumn(e.row, "voy_no", "");
				this.OTCStlInvoDetailDS.setColumn(e.row, "gl_acc_code", "");
				this.OTCStlInvoDetailDS.setColumn(e.row, "team_code", "");
			}
		}
		if(e.columnid == "voy_no" ) {
			if( e.newvalue != "0" ) {
				if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(e.row, "gl_acc_code")) ) {
					if( this.OTCStlInvoDetailDS.getColumn(e.row, "gl_acc_code") == "540203" ) {    // 고정비 은행수수료
						if( ( this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "0000" && this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "000"
							&& this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "00" && this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "0" ) ) {
							// 해당 VSL-VOY 항차의 CB 상의 '영업팀' 가져오기 !!
							var cb_team_code = await com.fnGetVoyNoSalesTeamCode(this, take.nvl(this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code")), take.nvl(this.OTCStlInvoDetailDS.getColumn(e.row, "voy_no")));
							//alert("cb_team_code : " + cb_team_code);
							// VSL-VOY 의 CB 영업팀값 으로 세팅
							this.OTCStlInvoDetailDS.setColumn(e.row, "team_code", cb_team_code);
						} else {
							await com.fnMessageOpenForm(this, "E", "은행수수료(540203) 계정은 '0000' 선박을 입력하실 수 없습니다.\n확인 바랍니다.");
							this.OTCStlInvoDetailDS.setColumn(e.row, "gl_acc_code","");
							this.OTCStlInvoDetailDS.setColumn(e.row, "team_code","");
							com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 1, e.row);
							return false;
						}
					}
				}
			} else {
				// 기존 입력값 Clear..
				this.OTCStlInvoDetailDS.setColumn(e.row, "gl_acc_code", "");
				this.OTCStlInvoDetailDS.setColumn(e.row, "team_code", "");
			}
		}
		//------------------------------------------------------------------------------------------------------------------------
		if(e.columnid == "clct_open_code") {
			this.OTCStlInvoDetailDS.set_enableevent(false);
			this.OTCStlInvoDetailDS.setColumn(e.row, "terms_date", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "pymt_term", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "due_date", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "pymt_hold_flag", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "bank_acc_id", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "bank_acc_desc", "");
			// hijang
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_1", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_2", "");
			//110411 GYJ
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_3", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_4", "");
			//130524 GYJ
			this.OTCStlInvoDetailDS.setColumn(e.row, "acc_code", "");
			this.OTCStlInvoDetailDS.set_enableevent(true);
			await this.fnSetDrCrAmt();
			await this.fnSetDiffAmt();
		} else if(e.columnid == "acc_code") {
			this.OTCStlInvoDetailDS.set_enableevent(false);
			this.OTCStlInvoDetailDS.setColumn(e.row, "bank_acc_id", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "bank_acc_desc", "");
			// hijang
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_1", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_2", "");
			//110411 GYJ
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_3", "");
			this.OTCStlInvoDetailDS.setColumn(e.row, "email_4", "");
			this.OTCStlInvoDetailDS.set_enableevent(true);
		} else if(e.columnid == "gl_acc_code") {
			var creType = this.OTCStlInvoDetailDS.getColumn(e.row, "clct_open_code");
			//if ( creType == null || creType == "") return false;
			if ( com.isEmpty(creType) ) return false;         // upgrade
			//if ((creType == "GLDR" && (varNewValue != "630601" && varNewValue != "800101" && varNewValue != "830101")) ||
			if ((creType == "GLDR" && (e.newvalue != "540203" && e.newvalue != "800101" && e.newvalue != "830101")) ||    // 630601 제거 -> 540203 추가 (HIJANG 20160906)
				(creType == "GLCR" && (e.newvalue != "730101" && e.newvalue != "760101"))) {
				await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0022");
				this.OTCStlInvoDetailDS.set_enableevent(false);
				this.OTCStlInvoDetailDS.setColumn(e.row, "gl_acc_code", "");
				this.OTCStlInvoDetailDS.set_enableevent(true);
				return false;
			}
			if((e.oldvalue == "800101" || e.oldvalue == "730101") && (e.newvalue != "800101" && e.newvalue != "730101")) {
				var locAmt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(e.row, "stl_loc_amt"), 0));
				// Usd, Krw 금액을 자동 재계산함
				await this.OTCStlInvoDetailDS_OnColumnChanged(obj, { row: e.row , columnid: "stl_loc_amt", newvalue: locAmt} );
			}
			//------------------------------------------------------------------------------------------------------------------------
			// 일반관리비 은행수수료('630601') -> 고정비 은행수수료('540203') 으로 계정 변경 관련 (20160906 HIJANG)
			//------------------------------------------------------------------------------------------------------------------------
			// 540203 계정 선택/입력 시,, 반드시 '순수영업팀' 이어야만 한다. !!
			if( e.newvalue == "540203" ) {     // 고정비 은행수수료(540203)
				// 0000 선박 또는 0000 항차 아닐경우..?
				if ( (( this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "0000" && this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "000"
						&& this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "00" && this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code") != "0" )
					 && nexacro.toNumber(this.OTCStlInvoDetailDS.getColumn(e.row, "voy_no")) != 0 ) ) {
					// 해당 VSL-VOY 항차의 CB 상의 '영업팀' 가져오기 !!
					var cb_team_code = await com.fnGetVoyNoSalesTeamCode(this, take.nvl(this.OTCStlInvoDetailDS.getColumn(e.row, "vsl_code")), take.nvl(this.OTCStlInvoDetailDS.getColumn(e.row, "voy_no")));
					//alert("cb_team_code : " + cb_team_code);
					// VSL-VOY 의 CB 영업팀값 으로 세팅
					this.OTCStlInvoDetailDS.setColumn(e.row, "team_code", cb_team_code);
				} else {
					await com.fnMessageOpenForm(this, "E", "은행수수료(540203) 계정은 '0000' 선박/항차를 입력하실 수 없습니다.\n확인 바랍니다.");
					this.OTCStlInvoDetailDS.setColumn(e.row, "gl_acc_code","");
					this.OTCStlInvoDetailDS.setColumn(e.row, "team_code","");
					com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, e.row);
					return false;
				}
				if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(e.row, "team_code")) ) {
					// 순수영업팀 여부 체크한다..!!
					var enable_flag = await com.isSalesTeamCodeCheck(this, this.OTCStlInvoDetailDS.getColumn(e.row, "team_code"));
					//alert("enable_flag : " +enable_flag);
					if( enable_flag == "N" ) {  // 비영업팀
						await com.fnMessageOpenForm(this, "E", "은행수수료(540203) 계정은 영업팀만 선택하실 수 있습니다.\n확인 바랍니다.");
						this.OTCStlInvoDetailDS.setColumn(e.row, "team_code","");     // 팀코드 clear
						com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 5, e.row);
						return false;
					}
				}
			}
		} else if(e.columnid == "stl_loc_amt") {
			this.OTCStlInvoDetailDS.set_enableevent(false);
			if(this.OTCStlInvoDetailDS.getColumn(e.row, "curcy_code") == "USD") {
				//OTCStlInvoDetailDS.SetColumn(nRow, "stl_usd_amt", toNumber(varNewValue));
				this.OTCStlInvoDetailDS.setColumn(e.row, "stl_usd_amt", new nexacro.Decimal(com.replace(take.nvl(e.newvalue, 0),",","")));    // upgrade
			} else {
				//OTCStlInvoDetailDS.SetColumn(nRow, "stl_usd_amt", round(toNumber(varNewValue) * usdLocExcRate, 2));
				this.OTCStlInvoDetailDS.setColumn(e.row, "stl_usd_amt", nexacro.round(new nexacro.Decimal(com.replace(take.nvl(e.newvalue, 0),",","")).mul(this.usdLocExcRate), 2));    // upgrade
			}
			if(this.OTCStlInvoDetailDS.getColumn(e.row, "curcy_code") == "KRW") {
				//OTCStlInvoDetailDS.SetColumn(nRow, "stl_krw_amt", toNumber(varNewValue));
				this.OTCStlInvoDetailDS.setColumn(e.row, "stl_krw_amt", new nexacro.Decimal(com.replace(take.nvl(e.newvalue, 0),",","")));    // upgrade
			} else {
				//OTCStlInvoDetailDS.SetColumn(nRow, "stl_krw_amt", Truncate(toNumber(varNewValue) * locExcRate));
				this.OTCStlInvoDetailDS.setColumn(e.row, "stl_krw_amt", Math.trunc(new nexacro.Decimal(com.replace(take.nvl(e.newvalue, 0),",","")).mul(this.locExcRate))); // upgrade
			}
			this.OTCStlInvoDetailDS.set_enableevent(true);
			await this.fnSetDrCrAmt();
			await this.fnSetDiffAmt();
		} else if(e.columnid == "stl_usd_amt" || e.columnid == "stl_krw_amt" ) {
			await this.fnSetDrCrAmt();
			await this.fnSetDiffAmt();
		} else if(e.columnid == "terms_date" ) {
			await this.fnGetDueDate(e.row);
		} else if(e.columnid == "pymt_term" ) {
			await this.fnGetDueDate(e.row);
		} else if(e.columnid == "due_date" ) {
			/*
			// 법원허가번호 clear..
			OTCStlInvoDetailDS.SetColumn(nRow, "court_admit_no", "");
			OTCStlInvoDetailDS.SetColumn(nRow, "court_flag", "");
			*/
		}
		//------------------------------------------------------------------------------------------------------------------------
		// 일반관리비 은행수수료('630601') -> 고정비 은행수수료('540203') 으로 계정 변경 관련 (20160906 HIJANG)
		//------------------------------------------------------------------------------------------------------------------------
		// 540203 계정 선택/입력 시,, 반드시 '순수영업팀' 이어야만 한다. !!
		if(e.columnid == "team_code" ) {
			var glAccCode = this.OTCStlInvoDetailDS.getColumn(e.row, "gl_acc_code");
			//alert("glAccCode : " + glAccCode);
			if( glAccCode == "540203" ) {
				if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(e.row, "team_code")) ){
					var enable_flag = await com.isSalesTeamCodeCheck(this, this.OTCStlInvoDetailDS.getColumn(e.row, "team_code"));
					//alert("enable_flag : " +enable_flag);
					if( enable_flag == "N"){  // 비영업팀
						await com.fnMessageOpenForm(this, "E", "은행수수료(540203) 계정은 영업팀만 선택하실 수 있습니다.\n확인 바랍니다.");
						this.OTCStlInvoDetailDS.setColumn(e.row, "team_code","");     // 팀코드  clear
						//g_setGridPositionXY(gd_InvoiceDS, OTCStlInvoDetailDS, 6, nRow);
						return false;
					}
				}
			}
		}
	}).call(this);
};

this.gd_InvoiceDS_OnCellPosChanged = function(obj:nexacro.Grid, e:nexacro.GridSelectEventInfo)
{
    if (e.oldcell == 4) {
        com.commCodeInquiryForGrid(this, "accountCode", obj, "acc_code", "" , e.oldrow, e.oldcell);
    } else if (e.oldcell == 5) {
        com.commCodeInquiryForGrid(this, "unSettleAccCode", obj, "gl_acc_code", "" , e.oldrow, e.oldcell);
    } else if (e.oldcell == 6) {
        com.commCodeInquiryForGrid(this, "activeTeamCode", obj, "team_code", "" , e.oldrow, e.oldcell);
    }
};

this.OTCStlInvoDetailDS_CanColumnChange = function(obj:nexacro.NormalDataset, e:nexacro.DSColChangeEventInfo)
{
    (async () => {
        if(e.columnid == "pymt_term")
        {
            if(!com.isEmpty(com.replace(e.newvalue,"-","")))
            { // upgrade
                var openCode = this.OTCStlInvoDetailDS.getColumn(e.row, "clct_open_code");
                if (com.isEmpty(openCode))
                { // upgrade
                    await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Type"));
                    this.OTCStlInvoDetailDS.set_enableevent(false);
					this.OTCStlInvoDetailDS.setColumn(e.row, "pymt_term", null);
					this.OTCStlInvoDetailDS.set_enableevent(true);
					return false;
                }
                if(openCode == "AP" && this.PaymentTermAPDS.findRow("code", e.newvalue) == -1)
                {
                    await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_2100.VAL_0007", "code", "Payment Term(AP)"));
                    this.OTCStlInvoDetailDS.set_enableevent(false);
					this.OTCStlInvoDetailDS.setColumn(e.row, "pymt_term", null);
					this.OTCStlInvoDetailDS.set_enableevent(true);
					return false;
                } else if(openCode == "AR" && this.PaymentTermARDS.findRow("code", e.newvalue) == -1) {
                    await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_2100.VAL_0007", "code", "Payment Term(AR)"));
                    this.OTCStlInvoDetailDS.set_enableevent(false);
					this.OTCStlInvoDetailDS.setColumn(e.row, "pymt_term", null);
					this.OTCStlInvoDetailDS.set_enableevent(true);
					return false;
                }
            }
        }
        //중복 거래처 check (130523 GYJ)
        if(e.columnid == "acc_code")
        {
			var openCode = this.OTCStlInvoDetailDS.getColumn(e.row, "clct_open_code");
            if (openCode == "AP" || openCode == "AR")
            {
                var arrArg = await com.getAllCommCode(this, "accountCodeAll", e.newvalue, null);
				if(arrArg[0]=="" || arrArg[0]==null) {
					this.OTCStlInvoDetailDS.set_enableevent(false);
					this.OTCStlInvoDetailDS.setColumn(e.row, "acc_code", e.oldvalue);
					this.OTCStlInvoDetailDS.set_enableevent(true);
					return false;
				}
                var acc_dupFlag = arrArg[9];
                var activeFlag = arrArg[5];
                //Active인데 dupe flag = 'y' 인 경우 error
                if (activeFlag == 'ACTIVE')
                {
                    if (acc_dupFlag == 'Y')
                    {
                        com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, e.row);
                        var result = await com.fnMessageOpenForm(this, "C", "중복으로 사용이 제한된 거래처로 아래의 거래처를 사용 하시기 바랍니다."
                                    +"\n\n("+arrArg[10]+") "+arrArg[11]
                                    +"\n\n 해당 거래처를 사용 하시겠습니까.?");
                        if (result == 'YES')
                        {
                            this.OTCStlInvoDetailDS.setColumn(e.row,"acc_code",arrArg[10]);
                            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, e.row);
                        }else{
                            this.OTCStlInvoDetailDS.setColumn(e.row,"acc_code","");
                            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, e.row);
                        }
                        return false;
                    }
                } else {
					//Inactive인 경우 정산이든 발생이든 전표 발생 불가.
					await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0075");
					com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, e.row);
					return false;
                }
            }
        }
    }).call(this);
};

