this.fnOnLoadCallback = function(svcid, errcd, errmsg)
{
    if (errcd == -1) {
        com.fnMessageOpenForm(this, 'S', errmsg);
    } else {
        var sysToday = com.somToday(this, 'h');
		trace("###############sysToday:::", sysToday);
        // 9시 이전 이면 이전날짜 default
        if(nexacro.toNumber(com.substr(sysToday, 8, 2)) >= 9) {
            sysToday = com.somToday(this, 'd'); //com.left(sysToday, 8);
        } else {
            sysToday = take.getAddDays(com.left(sysToday, 8), -1);
        }
        this.somToday = com.left(sysToday, 8);
        this.OTCStlHeadDS.set_enableevent(false);
        this.OTCStlHeadDS.setColumn(0, "team_name", nexacro.getApplication().gdsUserInfo.getColumn(0,"teamName"));
        this.OTCStlHeadDS.setColumn(0, "team_code", nexacro.getApplication().gdsUserInfo.getColumn(0,"teamCode"));
        this.OTCStlHeadDS.setColumn(0, "posting_date", this.somToday);
        this.OTCStlHeadDS.set_enableevent(true);
        this.OTCStlHeadDS.setColumn(0, "curcy_code", "USD");
        this.currencyCol = "USD";
        //검색조건(날짜) default 설정
		//this.SearchDS.setColumn(0, "from_date", take.getAddMonths(this.somToday, -1));
		this.SearchDS.setColumn(0, "from_date", take.getStrData(take.getAddMonths(this.somToday, -1)).date);
        this.SearchDS.setColumn(0, "to_date", this.somToday);
        //120726 GYJ
        // -> 김경미 대리 due_date default 날짜 설정 제거 요청(2012.10.11) hijang
        //SearchDS.SetColumn(0, "from_due_date", AddMonth(somToday, -1));
        //SearchDS.SetColumn(0, "to_due_date", somToday);
        this.gd_TermARDS.set_visible(false);
        this.gd_TermAPDS.set_visible(false);
        this.ed_accntCode1.setFocus();
    }
};

this.fnInquiryCallback = function(svcid, errcd, errmsg)
{
    if (errcd == -1) {
        com.fnMessageOpenForm(this, 'S', errmsg);
    } else {
        this.fnSetPropBkColorAndEdit();  // 정산 DS에 대해 정산 칼럼의 Back Color  및 Edit 속성 세팅함
    }
};

// Save하면서 동시에 Request 하도록 함. pending을 바로 하기 위함.
this.fnSaveCallback = function(svcid, errcd, errmsg)
{
    (async () => {
        if (errcd == -1) {
            com.fnMessageOpenForm(this, 'S', errmsg);
        } else {
            if( await this.fnPreReceiptAccYn() ) {
                await com.fnMessageOpenForm(this, "E", "마감일 지난 선수금 계정이 존재합니다.\n저장 완료 후, 상세화면에서 사유서를 작성하시기 바랍니다.");
                await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0017");
                this.OTCStlSettleDetailDS.clearData();
                this.OTCStlInvoDetailDS.clearData();
                this.OTCStlSettleDetailSaveDS.clearData();
            }else{
				//----------------------------- [시작] AP 전표에 대해서, HOLD 관련 '알림메시지 창' 띄우기 (HIJANG 20200508)  --------------------------------//
				var v_due_date;
				var v_ap_cnt = 0;
				for(var i=0; i < this.OTCStlInvoDetailDS.rowcount; i++)
				{
					//alert("clct_open_code : " + OTCStlInvoDetailDS.GetColumn(i, "clct_open_code"));
					if( this.OTCStlInvoDetailDS.getColumn(i, "clct_open_code") == "AP" ) {     // AP 일때
						v_due_date = com.dateFormatString(this.OTCStlInvoDetailDS.getColumn(i, "due_date"));
						if( com.isEmpty(v_due_date) ) {
							await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Due Date"));
							//me_due_date.SetFocus();
							return false;
						}
						// 1) 시간 확인용 : due_date
						var dueDate_flag = await com.getDueDateCheck(this, com.substr(v_due_date,0,8));
						//alert("dueDate_flag : " + dueDate_flag);
						if( dueDate_flag != "Y" ) {
							await com.fnMessageOpenForm(this, "E", dueDate_flag);
							return false;
						}
						v_ap_cnt++;
					}
				}
				//alert("v_ap_cnt : " + v_ap_cnt);
				//alert("stl_no : " + OTCStlHeadDS.GetColumn(0,"stl_no"));
				// 2) 송금건/비송금건 메시지 처리  : gl_date   -> ap 존재할때만 체크
				if( v_ap_cnt > 0 )
				{
					var postingDate = com.dateFormatString(this.me_postingDate.value);
					var year = com.substr(postingDate, 0, 4);
					var month = com.substr(postingDate, 4, 2);
					var day = com.substr(postingDate, 6, 2);
					//alert("year : " + year);
					//alert("month : " + month);
					//alert("day : " + day);
					var param = "functionGubun='AP_COUNT_INFO_SEARCH'";
						param += " aprvKey=" + nexacro.wrapQuote("OOTC06");        // 해당 전표 service Id
						param += " srcTrxNo=" + nexacro.wrapQuote(take.nvl(this.OTCStlHeadDS.getColumn(0,"stl_no")));    // 전표번호
						param += " gubun=" + nexacro.wrapQuote("SOMO");
					this.ApCountInfoDS.clearData();
					com.syncTransaction(this, "AP_COUNT_INFO_SEARCH", "SVC_LOC::commonService/AP_COUNT_INFO_SEARCH.do", "", "ApCountInfoDS=ApCountInfoDS", param, "");
					//alert("tot_ap_cnt : " + ApCountInfoDS.GetColumn(0, "tot_ap_cnt"));
					//alert("pymt_hold_cnt : " + ApCountInfoDS.GetColumn(0, "pymt_hold_cnt"));
					//alert("non_pymt_hold_cnt : " + ApCountInfoDS.GetColumn(0, "non_pymt_hold_cnt"));
					var tcnt; // 총건수
					var cnt; // 송금
					var ncnt; // 송금보류
						tcnt =  this.ApCountInfoDS.getColumn(0, "tot_ap_cnt");
						cnt  =  this.ApCountInfoDS.getColumn(0, "non_pymt_hold_cnt");
						ncnt =  this.ApCountInfoDS.getColumn(0, "pymt_hold_cnt");
					var param = "msgType=" + nexacro.wrapQuote("C");
						//param += " message=" + nexacro.wrapQuote("Domain.msg.common.VAL_0178");
                        param+= " message=" + com.replace("Domain.msg.common.VAL_0178", {year: year, month: month, day: day, tcnt: tcnt, cnt: cnt, ncnt: ncnt}).replaceAll(String.fromCharCode(10),"▼");
                    var result = await com.Dialog(this, 'biz::common/PaperLessMessageForm.xfdl', param, 660, 330);
					//var result = com.Dialog(pThis, 'biz::common/PaperLessMessageForm.xfdl', com.replace(com.replace(com.replace(com.replace(com.replace(com.replace(param, "@year", year), "@month", month), "@day", day), "@tcnt", tcnt), "@cnt", cnt), "@ncnt", ncnt), 660, 330);
					//var result = await com.Dialog(this, 'biz::common/PaperLessMessageForm.xfdl', com.replace(param, {year: "year", month: "month", day: "day", tcnt: "tcnt", cnt: "cnt", ncnt: "ncnt"}), 660, 330);
					//com.fnMessageOpenForm(this, "C", "");
					//alert("result : " + result);
					if (result == 0 || com.length(take.getTrim(result)) == 0) return; // upgrade
					if (result == "CANCEL") {
						return false;
					}
				}
				//----------------------------- [종료] AP 전표에 대해서, HOLD 관련 '알림메시지 창' 띄우기 (HIJANG 20200508)  --------------------------------//
				this.fnRequestTransaction();    // 저장시 바로 결재실행 못하도록 처리함. ( HIJANG - 20110526 )
            }
        }
    }).call(this);
};

this.fnRequestCallback = function(svcid, errcd, errmsg)
{
	(async () => {
		if (errcd == -1) {
			com.fnMessageOpenForm(this, 'S', errmsg);
		} else {
			//if(CCDAprvReqMDS.GetColumn(0, 'aprv_req_key') != null && CCDAprvReqMDS.GetColumn(0, 'aprv_req_key') != "")  {
			if( !com.isEmpty(this.CCDAprvReqMDS.getColumn(0, "aprv_req_key"))) {    // upgrade
				this.OZToPDF();
			} else {
				await com.fnMessageOpenForm(this, 'S', "결재 정보 가져오는 중 에러가 발생했습니다. ~r~n Setoff List 화면에서 재결재 하세요");
			}
			this.OTCStlSettleDetailDS.clearData();
			this.OTCStlInvoDetailDS.clearData();
			this.OTCStlSettleDetailSaveDS.clearData();
		}
	}).call(this);
};

this.fnGetExcRateCallback = function(svcid, errcd, errmsg)
{
    if (errcd == -1) {
        com.fnMessageOpenForm(this, "E", errmsg);
    } else{
        this.OTCStlHeadDS.setColumn(0, "loc_exc_rate", new nexacro.Decimal(take.nvl(this.TempRateDS.getColumn(0, "loc_rate"))));
        this.OTCStlHeadDS.setColumn(0, "usd_exc_rate", new nexacro.Decimal(take.nvl(this.TempRateDS.getColumn(0, "usd_rate"))));
        this.OTCStlHeadDS.setColumn(0, "usd_loc_rate", new nexacro.Decimal(take.nvl(this.TempRateDS.getColumn(0, "loc_usd_rate"))));
    }
    this.locExcRate = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "loc_exc_rate")));
    this.usdLocExcRate = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "usd_loc_rate")));
};

