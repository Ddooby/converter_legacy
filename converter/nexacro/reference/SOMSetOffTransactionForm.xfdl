            param += "functionGubun=AgentEmailList";
            param += " account_code=" + nexacro.wrapQuote(take.nvl(acc_code));
            param += " account_name=" + nexacro.wrapQuote("");
            result = await com.Dialog(this, 'biz::da/prepaymentSendInvoice/AgentEmailForm.xfdl', param, "660", "456");
            if (result == 0 || com.length(take.getTrim(result)) == 0) return; // upgrade 박진석
            //if (result[0] != null) {
            if ( !com.isEmpty(result[0]) ) {     // upgrade
                this.OTCStlInvoDetailDS.setColumn(cursorRowPos, "email_4", result[1]);
            }
        }
        /*
        // 법원허가번호 팝업창 띄우기
        else if (nCell == 23 && cursorCellPos == 23) {
                var team_code = OTCStlInvoDetailDS.GetColumn(cursorRowPos, "team_code");
