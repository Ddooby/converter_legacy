this.btn_curcyDiff_OnClick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	(async () => {
		// 기존 환차손익 삭제
		for (var nRow = this.OTCStlInvoDetailDS.rowcount - 1; nRow >= 0; nRow--) {
			var glAccCode = this.OTCStlInvoDetailDS.getColumn(nRow, "gl_acc_code");
			if (glAccCode == "730101" || glAccCode == "800101") {
				this.OTCStlInvoDetailDS.deleteRow(nRow);
			}
		}
		await this.fnSetDrCrAmt();
		await this.fnSetDiffAmt();
		
		//---------------------------------------------------------------------------------------
		// [ 계산 오류 해결 ] - hijang ( 20110926 )
		// 여러line에 대해서 정산처리 할때,,
		// diff_amt 값에 이상한 dummy 데이터가 붙는 현상 발생함 ( ex. -0.0000005 )
		// -> Mi-platform 버그가 아닌지..
		// 하여튼, 이 문제를 해결하기 위해서 round 처리하여 문제 해결함.
		//  ( 현재 데이터는 소수점 2자리가 max 이므로,, 강제로 2자리에서 Truncate 하였음 )
		//---------------------------------------------------------------------------------------
		/*
		this.me_loc_diff_amt.set_value(Math.trunc(new nexacro.Decimal(take.nvl(this.me_loc_diff_amt.value)), 2));
		this.me_usd_diff_amt.set_value(Math.trunc(new nexacro.Decimal(take.nvl(this.me_usd_diff_amt.value)), 2));
		this.me_krw_diff_amt.set_value(Math.trunc(new nexacro.Decimal(take.nvl(this.me_krw_diff_amt.value)), 3));
		*/
		this.me_loc_diff_amt.set_value(nexacro.floor(new nexacro.Decimal(take.nvl(this.me_loc_diff_amt.value)), 3));
		this.me_usd_diff_amt.set_value(nexacro.floor(new nexacro.Decimal(take.nvl(this.me_usd_diff_amt.value)), 3));
		this.me_krw_diff_amt.set_value(nexacro.floor(new nexacro.Decimal(take.nvl(this.me_krw_diff_amt.value)), 4));
		
		var locDiff = this.me_loc_diff_amt.value;
		var usdDiff = this.me_usd_diff_amt.value;
		var krwDiff = this.me_krw_diff_amt.value;
		if( nexacro.toNumber(usdDiff) == 0 && nexacro.toNumber(krwDiff) == 0 ) return;
		
		var curcyCnt = this.OTCStlSettleDetailDS.getCaseCount("check_item == 1 && curcy_code != '" + this.currencyCol + "'");
		if( curcyCnt == 0 ) {   // Master와 동일한 화폐만으로 발생, 정산이 이뤄진 경우 Loc 금액의 Balance 체크
			if(nexacro.toNumber(locDiff) != 0) {
				await com.fnMessageOpenForm(this, "I", "LOC 금액이 0 이어야 환차손익 생성이 가능합니다.");
				return false;
			}
		}
		if(this.currencyCol == "USD" && nexacro.toNumber(usdDiff) != 0) {
			await com.fnMessageOpenForm(this, "I", "USD 금액이 0 이어야 환차손익 생성이 가능합니다.");
			return false;
		} else if(this.currencyCol == "KRW" && nexacro.toNumber(krwDiff) != 0) {
			await com.fnMessageOpenForm(this, "I", "KRW 금액이 0 이어야 환차손익 생성이 가능합니다.");
			return false;
		}
		var fRow = this.OTCStlSettleDetailDS.findRow("check_item", 1);
		var addRow = 0;
		this.OTCStlInvoDetailDS.set_enableevent(false);
		if( nexacro.toNumber(usdDiff) * nexacro.toNumber(krwDiff) >= 0 ) {  //두 값의 Sign이 같거나 하나가 0 인경우
			addRow = this.OTCStlInvoDetailDS.addRow();
			this.OTCStlInvoDetailDS.setColumn(addRow, "curcy_code", this.OTCStlHeadDS.getColumn(0, "curcy_code"));
			this.OTCStlInvoDetailDS.setColumn(addRow, "team_code", this.OTCStlHeadDS.getColumn(0, "team_code"));
			this.OTCStlInvoDetailDS.setColumn(addRow, "stl_loc_amt", 0);
			if(fRow >= 0) {
				this.OTCStlInvoDetailDS.setColumn(addRow, "vsl_code", this.OTCStlSettleDetailDS.getColumn(fRow, "vsl_code"));
				this.OTCStlInvoDetailDS.setColumn(addRow, "voy_no", this.OTCStlSettleDetailDS.getColumn(fRow, "voy_no"));
				this.OTCStlInvoDetailDS.setColumn(addRow, "acc_code", this.OTCStlSettleDetailDS.getColumn(fRow, "acc_code"));
			}
			if( nexacro.toNumber(usdDiff) <= 0 && nexacro.toNumber(krwDiff) <= 0 ) {
				this.OTCStlInvoDetailDS.setColumn(addRow, "clct_open_code", "GLDR");
				this.OTCStlInvoDetailDS.setColumn(addRow, "gl_acc_code", "800101");
			} else {
				this.OTCStlInvoDetailDS.setColumn(addRow, "clct_open_code", "GLCR");
				this.OTCStlInvoDetailDS.setColumn(addRow, "gl_acc_code", "730101");
			}
			this.OTCStlInvoDetailDS.setColumn(addRow, "stl_usd_amt", Math.abs(nexacro.toNumber(usdDiff)));
			this.OTCStlInvoDetailDS.setColumn(addRow, "stl_krw_amt", Math.abs(nexacro.toNumber(krwDiff)));
		} else {  // 두 값의 Sign이 다른 경우
			if (nexacro.toNumber(usdDiff) < 0 || nexacro.toNumber(krwDiff) < 0) {
				addRow = this.OTCStlInvoDetailDS.addRow();
				this.OTCStlInvoDetailDS.setColumn(addRow, "curcy_code", this.OTCStlHeadDS.getColumn(0, "curcy_code"));
				this.OTCStlInvoDetailDS.setColumn(addRow, "team_code", this.OTCStlHeadDS.getColumn(0, "team_code"));
				this.OTCStlInvoDetailDS.setColumn(addRow, "stl_loc_amt", 0);
				if(fRow >= 0) {
					this.OTCStlInvoDetailDS.setColumn(addRow, "vsl_code", this.OTCStlSettleDetailDS.getColumn(fRow, "vsl_code"));
					this.OTCStlInvoDetailDS.setColumn(addRow, "voy_no", this.OTCStlSettleDetailDS.getColumn(fRow, "voy_no"));
					this.OTCStlInvoDetailDS.setColumn(addRow, "acc_code", this.OTCStlSettleDetailDS.getColumn(fRow, "acc_code"));
				}
				this.OTCStlInvoDetailDS.setColumn(addRow, "clct_open_code", "GLDR");
				this.OTCStlInvoDetailDS.setColumn(addRow, "gl_acc_code", "800101");
				if(nexacro.toNumber(usdDiff) < 0) {
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_usd_amt", Math.abs(nexacro.toNumber(usdDiff)));
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_krw_amt", 0);
				}
				if(nexacro.toNumber(krwDiff) < 0) {
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_usd_amt", 0);
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_krw_amt", Math.abs(nexacro.toNumber(krwDiff)));
				}
			}
			if (nexacro.toNumber(usdDiff) > 0 || nexacro.toNumber(krwDiff) > 0) {
				addRow = this.OTCStlInvoDetailDS.addRow();
				this.OTCStlInvoDetailDS.setColumn(addRow, "curcy_code", this.OTCStlHeadDS.getColumn(0, "curcy_code"));
				this.OTCStlInvoDetailDS.setColumn(addRow, "team_code", this.OTCStlHeadDS.getColumn(0, "team_code"));
				this.OTCStlInvoDetailDS.setColumn(addRow, "stl_loc_amt", 0);
				if(fRow >= 0) {
					this.OTCStlInvoDetailDS.setColumn(addRow, "vsl_code", this.OTCStlSettleDetailDS.getColumn(fRow, "vsl_code"));
					this.OTCStlInvoDetailDS.setColumn(addRow, "voy_no", this.OTCStlSettleDetailDS.getColumn(fRow, "voy_no"));
					this.OTCStlInvoDetailDS.setColumn(addRow, "acc_code", this.OTCStlSettleDetailDS.getColumn(fRow, "acc_code"));
				}
				this.OTCStlInvoDetailDS.setColumn(addRow, "clct_open_code", "GLCR");
				this.OTCStlInvoDetailDS.setColumn(addRow, "gl_acc_code", "730101");
				if(nexacro.toNumber(usdDiff) > 0) {
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_usd_amt", nexacro.toNumber(usdDiff));
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_krw_amt", 0);
				}
				if(nexacro.toNumber(krwDiff) > 0) {
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_usd_amt", 0);
					this.OTCStlInvoDetailDS.setColumn(addRow, "stl_krw_amt", nexacro.toNumber(krwDiff));
				}
			}
		}
		this.OTCStlInvoDetailDS.set_enableevent(true);
		await this.fnSetDrCrAmt();
		await this.fnSetDiffAmt();
	}).call(this);
};

this.btn_mic_OnClick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo) {
    (async () => {
        var param = "windowTitle=" + nexacro.wrapQuote("UserCode");
            param += " kind=userCode";
            param += " strSeletedCodeDS=MICMultiSearchDS";
            param += " conditionValue="+nexacro.wrapQuote(take.nvl(this.ed_rcv_id.value));
            param += " conditionType="+nexacro.wrapQuote("NAME");
        var arrArg = await com.Dialog(this, 'biz::common/CommonCodePopupForm.xfdl', param, "660", "560", "Autosize=false");
        if (arrArg == 0 || com.length(take.getTrim(arrArg)) == 0) return; // upgrade 박진석
        //if(arrArg[0] != null && arrArg[1] != null) {
        if (!com.isEmpty(arrArg[0]) && !com.isEmpty(arrArg[1])) {     // upgrade
            this.ed_rcv_id.set_value(arrArg[0]);
            //this.st_username.set_text(arrArg[1]);
            //st_username.Text = arrArg[0];
        } else {
            this.ed_rcv_id.setFocus();
        }
    }).call(this);
};

