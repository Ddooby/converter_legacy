    <Script type="xscript5.1"><![CDATA[/**
 *  SOMSetOffTransactionForm
 *
 *  @MenuPath    Finance > 미결관리 > 채권채무상계 > 상세
 *  @FileName    SOMSetOffTransactionForm.xfdl
 *  @Creator     UXB
 *  @CreateDate  2025.09.01
 *  @Version     1.0
 *  @Desction    설명
 *
 ************************* 소스 수정 이력 ********************************
 *    Date          Modifier            Description
 **********************************************************************
 *  2025.09.01    	AICHanger          	자동변환
 *  2025.12.19   	정철환          	수동변환
 **********************************************************************
 */
//공통 라이브러리 호출

/*********************************************************
 * 1.1 FORM 변수 선언 영역
 ********************************************************/
this.f_usdExcRate = "";
this.somToday = "";   //오늘 일자 yyyymmdd
this.currencyCol = "",this.glAccName = "";

this.locExcRate = new nexacro.Decimal(0),this.usdLocExcRate = new nexacro.Decimal(0);

/*********************************************************
 * 1.2 FORM EVENT 영역(onload등)
 ********************************************************/
//Form_onload 최초 로드시 발생되는 이벤트 (필수)
this.Form_onload = function(obj:nexacro.Form,e:nexacro.LoadEventInfo)
{
    if (take.formOnLoad(this))
    {
        this.fnInit();
    }
};

this.form_OnTimer = function(obj:nexacro.Form, e:nexacro.TimerEventInfo) {
    if(e.timerid == common_oz.G_OzTimerID) {
        com.ApprovalFileSearch(this);
    } else {
        this.killTimer(0);
    }
};

/****************************************************************************************
 * 2 필수 FUNCTION 영역 (fnInit, fnSearch, fnSave, fnAdd, fnDel, fnExcel, fnPrint)
****************************************************************************************/
this.fnInit = function()
{
	com.drawGridDisableColor(this);

	this.currencyDS.clearData();
	this.PaymentTermAPDS.clearData();
	this.PaymentTermARDS.clearData();

    var param = "functionGubun=SETOFF_ONLOAD";
    com.syncTransaction(this, "init", "SVC_LOC::brokerageIncomeSettlement/SETOFF_ONLOAD.do", "", "currencyDS=currencyDS PaymentTermAPDS=PaymentTermAPDS PaymentTermARDS=PaymentTermARDS", param, "fnOnLoadCallback");
};

this.fnSearch = function()
{
	(async () => {
		// OTCStlHeadDS 체크
		var postingDate = com.dateFormatString(this.OTCStlHeadDS.getColumn(0, "posting_date"));
		// GL date 체크
		//if (postingDate == null) {
		if (com.isEmpty(postingDate)) { // upgrade
			await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "GL Date"));
			this.me_postingDate.setFocus();
			return false;
		}
		if (!com.isValidDate(this.me_postingDate)) {
			this.me_postingDate.setFocus();
			return false;
		}
		if (nexacro.toNumber(com.left(postingDate, 8)) > nexacro.toNumber(this.somToday)) {
			await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_2100.VAL_0056", "input", "GL Date"));
			this.me_postingDate.setFocus();
			return false;
		}
		//  curcy_code 체크
		//if (OTCStlHeadDS.getColumn(0, "curcy_code") == null) {
		if( com.isEmpty(this.OTCStlHeadDS.getColumn(0, "curcy_code"))) {    // upgrade
			await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Currency"));
			this.cb_currency.setFocus();
			return false;
		}
		// SearchDS 체크
		/*
		// ACCOUNT 필수 조회항목에서 제외 (20131106)  - hijang
		//if (ed_accntCode1.Text == "") {
		if(g_isEmpty(ed_accntCode1.text)) { // upgrade
			g_fnMessageOpenForm("E", Replace("Domain.msg.common.VAL_0001", "input",  "Account"));
			ed_accntCode1.SetFocus();
			return;
		}
		*/
		//if (me_fromDate.Text == "") {
		if(com.isEmpty(this.me_fromDate.value)) { // upgrade
			await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0044", "input", "GL Date (From)"));
			this.me_fromDate.setFocus();
			return;
		}
		//if (me_toDate.Text == "") {
		if(com.isEmpty(this.me_toDate.value)) { // upgrade
			await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0044", "input", "GL Date (To)"));
			this.me_toDate.setFocus();
			return;
		}
		if (!com.isValidDate(this.me_fromDate)) {
			this.me_fromDate.setFocus();
			return false;
		}
		if (!com.isValidDate(this.me_toDate)) {
			this.me_toDate.setFocus();
			return false;
		}
		if (nexacro.toNumber(com.dateFormatString(this.me_fromDate.value)) > nexacro.toNumber(com.dateFormatString(this.me_toDate.value))) {
			await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0045");
			this.me_fromDate.setFocus();
			return;
		}
		//120726 GYJ
		if (nexacro.toNumber(com.dateFormatString(this.me_fromDueDate.value)) > nexacro.toNumber(com.dateFormatString(this.me_toDueDate.value))) {
			await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0045");
			this.me_fromDueDate.setFocus();
			return;
		}
		//본경 선택 시 필수가 아님 170822 GYJ
		if(this.ck_GL.value != "1"){
			//if (ed_glAccCode.Text == "") {
			if(com.isEmpty(this.ed_glAccCode.value)) { // upgrade
				await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "GL Account"));
				this.ed_glAccCode.setFocus();
				return;
			}
		}
		//120726 GYJ
		if (!com.isValidDate(this.me_fromDueDate)) {
			this.me_fromDueDate.setFocus();
			return false;
		}
		if (!com.isValidDate(this.me_toDueDate)) {
			this.me_toDueDate.setFocus();
			return false;
		}
		var arrAccntCode = "", arrTeamCode = "", arrVslCode = "", arrVoyNo = "", arrVslVoy = "", arrGlAccCode = "";
		/*
		if ( ed_accntCode1.Text != "" ) arrAccntCode = "'" + ed_accntCode1.Value + "',";
		if ( ed_accntCode2.Text != "" ) arrAccntCode = arrAccntCode + "'" + ed_accntCode2.Value + "',";
		if ( ed_accntCode3.Text != "" ) arrAccntCode = arrAccntCode + "'" + ed_accntCode3.Value + "',";
		if ( ed_accntCode4.Text != "" ) arrAccntCode = arrAccntCode + "'" + ed_accntCode4.Value + "',";
		if ( arrAccntCode != "" ) arrAccntCode = left(arrAccntCode, length(arrAccntCode) - 1);
		if ( ed_teamCode1.Text != "" ) arrTeamCode = "'" + ed_teamCode1.Value + "',";
		if ( ed_teamCode2.Text != "" ) arrTeamCode = arrTeamCode + "'" + ed_teamCode2.Value + "',";
		if ( ed_teamCode3.Text != "" ) arrTeamCode = arrTeamCode + "'" + ed_teamCode3.Value + "',";
		if ( ed_teamCode4.Text != "" ) arrTeamCode = arrTeamCode + "'" + ed_teamCode4.Value + "',";
		if ( arrTeamCode != "" ) arrTeamCode = left(arrTeamCode, length(arrTeamCode) - 1);
		*/
		// upgrade
		if ( !com.isEmpty(this.ed_accntCode1.value) ) arrAccntCode = "'" + this.ed_accntCode1.value + "',";
		if ( !com.isEmpty(this.ed_accntCode2.value) ) arrAccntCode += "'" + this.ed_accntCode2.value + "',";
		if ( !com.isEmpty(this.ed_accntCode3.value) ) arrAccntCode += "'" + this.ed_accntCode3.value + "',";
		if ( !com.isEmpty(this.ed_accntCode4.value) ) arrAccntCode += "'" + this.ed_accntCode4.value + "',";
		if ( !com.isEmpty(arrAccntCode) ) arrAccntCode = com.left(arrAccntCode, com.length(arrAccntCode) - 1);
		if ( !com.isEmpty(this.ed_teamCode1.value) ) arrTeamCode = "'" + this.ed_teamCode1.value + "',";
		if ( !com.isEmpty(this.ed_teamCode2.value) ) arrTeamCode += "'" + this.ed_teamCode2.value + "',";
		if ( !com.isEmpty(this.ed_teamCode3.value) ) arrTeamCode += "'" + this.ed_teamCode3.value + "',";
		if ( !com.isEmpty(this.ed_teamCode4.value) ) arrTeamCode += "'" + this.ed_teamCode4.value + "',";
		if ( !com.isEmpty(arrTeamCode) ) arrTeamCode = com.left(arrTeamCode, com.length(arrTeamCode) - 1);
		for(var row = 0; row < this.SlipAccMultiSearchDS.rowcount; row++) {
			if(row >= 10) {
				await com.fnMessageOpenForm(this, "I", "계정을 10개 이내로 선택해 주세요");
				return;
			}
			arrGlAccCode += "'" + this.SlipAccMultiSearchDS.getColumn(row, "code") + "',";
		}
		//if ( arrGlAccCode != "" ) arrGlAccCode = left(arrGlAccCode, length(arrGlAccCode) - 1);
		if ( !com.isEmpty(arrGlAccCode) ) arrGlAccCode = com.left(arrGlAccCode, com.length(arrGlAccCode) - 1);    // upgrade
		
		var vslVoyInqType1 = false;
		var vslVoyInqType2 = false;
		var vslVoyInqType3 = false;
		
		//if ( ed_vslCode1.Text != "" && ed_voyNo1.Text != "" ) {
		if( !com.isEmpty(this.ed_vslCode1.value) && !com.isEmpty(this.ed_voyNo1.value) ) {        // upgrade
			arrVslVoy += "('" + this.ed_vslCode1.value + "'," + this.ed_voyNo1.value + "),";
			vslVoyInqType1 = true;
		//} else if ( ed_vslCode1.Text != "" && ed_voyNo1.Text == "" ) {
		} else if( !com.isEmpty(this.ed_vslCode1.value) && com.isEmpty(this.ed_voyNo1.value) ) {        // upgrade
			arrVslCode += "'" + this.ed_vslCode1.value + "',";
			vslVoyInqType2 = true;
		//} else if ( ed_vslCode1.Text == "" && ed_voyNo1.Text != "" ) {
		} else if( com.isEmpty(this.ed_vslCode1.value) && !com.isEmpty(this.ed_voyNo1.value) ) {        // upgrade
			arrVoyNo += this.ed_voyNo1.value + ",";
			vslVoyInqType3 = true;
		}
		//if ( ed_vslCode2.Text != "" && ed_voyNo2.Text != "" ) {
		if( !com.isEmpty(this.ed_vslCode2.value) && !com.isEmpty(this.ed_voyNo2.value) ) {        // upgrade
			arrVslVoy += "('" + this.ed_vslCode2.value + "'," + this.ed_voyNo2.value + "),";
			vslVoyInqType1 = true;
		//} else if ( ed_vslCode2.Text != "" && ed_voyNo2.Text == "" ) {
		} else if( !com.isEmpty(this.ed_vslCode2.value) && com.isEmpty(this.ed_voyNo2.value) ) {        // upgrade
			arrVslCode += "'" + this.ed_vslCode2.value + "',";
			vslVoyInqType2 = true;
		//} else if ( ed_vslCode2.Text == "" && ed_voyNo2.Text != "" ) {
		} else if( com.isEmpty(this.ed_vslCode2.value) && !com.isEmpty(this.ed_voyNo2.value) ) {        // upgrade
			arrVoyNo += this.ed_voyNo2.value + ",";
			vslVoyInqType3 = true;
		}
		//if ( ed_vslCode3.Text != "" && ed_voyNo3.Text != "" ) {
		if( !com.isEmpty(this.ed_vslCode3.value) && !com.isEmpty(this.ed_voyNo3.value) ) {        // upgrade
			arrVslVoy += "('" + this.ed_vslCode3.value + "'," + this.ed_voyNo3.value + "),";
			vslVoyInqType1 = true;
		//} else if ( ed_vslCode3.Text != "" && ed_voyNo3.Text == "" ) {
		} else if( !com.isEmpty(this.ed_vslCode3.value) && com.isEmpty(this.ed_voyNo3.value) ) {        // upgrade
			arrVslCode += "'" + this.ed_vslCode3.value + "',";
			vslVoyInqType2 = true;
		//} else if ( ed_vslCode3.Text == "" && ed_voyNo3.Text != "" ) {
		} else if( com.isEmpty(this.ed_vslCode3.value) && !com.isEmpty(this.ed_voyNo3.value) ) {        // upgrade
			arrVoyNo += this.ed_voyNo3.value + ",";
			vslVoyInqType3 = true;
		}
		//if ( ed_vslCode4.Text != "" && ed_voyNo4.Text != "" ) {
		if( !com.isEmpty(this.ed_vslCode4.value) && !com.isEmpty(this.ed_voyNo4.value) ) {        // upgrade
			arrVslVoy += "('" + this.ed_vslCode4.value + "'," + this.ed_voyNo4.value + "),";
			vslVoyInqType1 = true;
		//} else if ( ed_vslCode4.Text != "" && ed_voyNo4.Text == "" ) {
		} else if( !com.isEmpty(this.ed_vslCode4.value) && com.isEmpty(this.ed_voyNo4.value) ) {        // upgrade
			arrVslCode += "'" + this.ed_vslCode4.value + "',";
			vslVoyInqType2 = true;
		//} else if ( ed_vslCode4.Text == "" && ed_voyNo4.Text != "" ) {
		} else if( com.isEmpty(this.ed_vslCode4.value) && !com.isEmpty(this.ed_voyNo4.value) ) {        // upgrade
			arrVoyNo += this.ed_voyNo4.value + ",";
			vslVoyInqType3 = true;
		}
		/*
		if ( arrVslVoy != "" ) arrVslVoy = left(arrVslVoy, length(arrVslVoy) - 1);
		if ( arrVslCode != "" ) arrVslCode = left(arrVslCode, length(arrVslCode) - 1);
		if ( arrVoyNo != "" ) arrVoyNo = left(arrVoyNo, length(arrVoyNo) - 1);
		*/
		// upgrade
		if ( !com.isEmpty(arrVslVoy) ) arrVslVoy = com.left(arrVslVoy, com.length(arrVslVoy) - 1);
		if ( !com.isEmpty(arrVslCode) ) arrVslCode = com.left(arrVslCode, com.length(arrVslCode) - 1);
		if ( !com.isEmpty(arrVoyNo) ) arrVoyNo = com.left(arrVoyNo, com.length(arrVoyNo) - 1);
		if ((vslVoyInqType1 == true && ( vslVoyInqType2 == true || vslVoyInqType3 == true )) ||
		   (vslVoyInqType2 == true && ( vslVoyInqType1 == true || vslVoyInqType3 == true )) ||
		   (vslVoyInqType3 == true && ( vslVoyInqType1 == true || vslVoyInqType2 == true )) ) {
		   await com.fnMessageOpenForm(this, "I", "(Vsl-Voy 조회 Type) 동일한 패턴으로만 Vsl-Voy를 조회해 주세요");
		   return;
		}
		var param  = "";
			param += "functionGubun=SETOFF_OpenInquiry";
			param += " accntCodeS=" + nexacro.wrapQuote(take.nvl(arrAccntCode));
			param += " teamCodeS=" + nexacro.wrapQuote(take.nvl(arrTeamCode));
			param += " glAccCodeS=" + nexacro.wrapQuote(take.nvl(arrGlAccCode));
			param += " onlyVslCodeS=" + nexacro.wrapQuote(take.nvl(arrVslCode));
			param += " onlyVoyNoS=" + nexacro.wrapQuote(take.nvl(arrVoyNo));
			param += " vslVoyS=" + nexacro.wrapQuote(take.nvl(arrVslVoy));
			param += " fromDate=" + nexacro.wrapQuote(take.nvl(com.left(com.dateFormatString(this.me_fromDate.value), 8)));
			param += " toDate=" + nexacro.wrapQuote(take.nvl(com.left(com.dateFormatString(this.me_toDate.value), 8)));
			param += " curcyCode=" + nexacro.wrapQuote(take.nvl(this.OTCStlHeadDS.getColumn(0, "curcy_code")));
			//120726 GYJ
			param += " fromDueDate=" + nexacro.wrapQuote(take.nvl(com.left(com.dateFormatString(this.me_fromDueDate.value), 8)));
			param += " toDueDate=" + nexacro.wrapQuote(take.nvl(com.left(com.dateFormatString(this.me_toDueDate.value), 8)));
			//170819 GYJ
			param += " curcyCode1=" + nexacro.wrapQuote(take.nvl(this.ed_curcy_code.value));
			param += " curcyType=" + nexacro.wrapQuote(take.nvl(this.cb_curcyType.value));
			param += " bongyeongGL=" + nexacro.wrapQuote(take.nvl(this.ck_GL.value));

		this.OTCStlSettleDetailDS.clearData();
		com.aSyncTransaction(this, "INQURIY", "SVC_LOC::brokerageIncomeSettlement/SETOFF_OpenInquiry.do", "", "OTCStlSettleDetailDS=OTCStlSettleDetailDS", param, "fnInquiryCallback");
	}).call(this);
};

this.fnSave = function()
{
	take.setWaitCall(this, this.fnSaveProc);
};

this.fnSaveProc = function()
{	
	(async() => {
		if (!await this.fnValidationCheck()) return;
		this.fnPymtSetting();
		// hijang - 20111130
		this.OTCStlHeadDS.setColumn(0, "alt_rcv_id", this.ed_rcv_id.value);
		this.OTCStlHeadDS.setColumn(0, "alt_rcv_team_code", this.ed_rcv_team_code.value);
		//alert("반영된 alt_rcv_team_code 값 : " + OTCStlHeadDS.GetColumn(0, "alt_rcv_team_code" ) );
		//alert("반영된 alt_rcv_id 값: " + OTCStlHeadDS.GetColumn(0, "alt_rcv_id" ) );
		// 예수금계정 자동 HOLD_FLAG = 'Y' 자동 세팅 (hijang 20200508)
		for(var i=0; i < this.OTCStlInvoDetailDS.rowcount; i++)
		{
			if( this.OTCStlInvoDetailDS.getColumn(i, "clct_open_code") == "AP" ) {     // AP 일때
				if( this.OTCStlInvoDetailDS.getColumn(i, "gl_acc_code") == "210409" || this.OTCStlInvoDetailDS.getColumn(i, "gl_acc_code") == "210802"
				 || this.OTCStlInvoDetailDS.getColumn(i, "gl_acc_code") == "210803" || this.OTCStlInvoDetailDS.getColumn(i, "gl_acc_code") == "210899" )
				{
					this.OTCStlInvoDetailDS.setColumn(i, "pymt_hold_flag", "1");
				}
			}
		}

		var param = "functionGubun=SETOFF_SAVE";
		this.OTCStlSettleDetailDS.filter("check_item=='1'");
		this.OTCStlSettleDetailSaveDS.copyData(this.OTCStlSettleDetailDS, true);
		//RYU Filter된 것만 넘어가는지 확인.
		//g_Sync_Transaction("save", "SVC_LOC::" + pageCtx + "/BrokerageIncomeSettlementServlet", "OTCStlHeadDS=OTCStlHeadDS:A OTCStlSettleDetailSaveDS=OTCStlSettleDetailSaveDS:A OTCStlInvoDetailDS=OTCStlInvoDetailDS:A", "OTCStlHeadDS=OTCStlHeadDS", param, "fnSaveCallback");
		com.syncTransaction(this, "save", "SVC_LOC::brokerageIncomeSettlement/SETOFF_SAVE.do", "OTCStlHeadDS=OTCStlHeadDS:A OTCStlSettleDetailSaveDS=OTCStlSettleDetailSaveDS:A OTCStlInvoDetailDS=OTCStlInvoDetailDS", "OTCStlHeadDS=OTCStlHeadDS", param, "fnSaveCallback");
	}).call(this);
    
};

this.fnClose = function()
{
	com.fnClose(this);
};

this.fnPrint = function()
{
    //PrintScreen(false, "Top" , "Left" );
    take.formPrint(this, "L");	// L:가로, P:세로
};

/*********************************************************
 * 3 각 COMPONENT 별 EVENT 영역
 ********************************************************/
 // TODO: MultiCommonCodePopupForOTCSettleForm.xfdl 확인필요
this.btn_glAccCode_OnClick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	(async () => {
		var param  = "windowTitle=" + nexacro.wrapQuote(take.nvl("GL Account"));
			param += " kind=unSettleAccCode";
			param += " strSeletedCodeDS=SlipAccMultiSearchDS";
		await com.Dialog(this, 'biz::common/MultiCommonCodePopupForOTCSettleForm.xfdl',param, 660, 450, "resizable=false", -1, -1);

		var count = this.SlipAccMultiSearchDS.rowcount;
		var accName = this.SlipAccMultiSearchDS.getColumn(0, "codename");
		var accCode = this.SlipAccMultiSearchDS.getColumn(0, "code");
		this.SearchDS.set_enableevent(false);
		if(count == 0) {
			this.SearchDS.setColumn(0, "gl_acc_code", "");
			this.SearchDS.setColumn(0, "gl_acc_name", "");
		} else {
			this.SearchDS.setColumn(0, "gl_acc_code", accCode);
			if(count > 1) {
				accName = accName + " 외 " + (count - 1 ) + " 건";
			}
			this.SearchDS.setColumn(0, "gl_acc_name", accName);
		}
		this.SearchDS.set_enableevent(true);
	}).call(this);
};

this.btn_del_OnClick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
	(async () => {
		this.OTCStlInvoDetailDS.deleteRow(this.OTCStlInvoDetailDS.rowposition);
		await this.fnSetDrCrAmt();
		await this.fnSetDiffAmt();
	}).call(this);
};

this.btn_add_OnClick = function(obj:nexacro.Button, e:nexacro.ClickEventInfo)
{
    var row = this.OTCStlInvoDetailDS.addRow();
    this.OTCStlInvoDetailDS.setColumn(row, "curcy_code", this.OTCStlHeadDS.getColumn(0, "curcy_code"));
    this.OTCStlInvoDetailDS.setColumn(row, "team_code", this.OTCStlHeadDS.getColumn(0, "team_code"));

    var fRow = this.OTCStlSettleDetailDS.findRow("check_item", 1);
    if (fRow >= 0) {
        this.OTCStlInvoDetailDS.setColumn(row, "vsl_code", this.OTCStlSettleDetailDS.getColumn(fRow, "vsl_code"));
        this.OTCStlInvoDetailDS.setColumn(row, "voy_no", com.lpad(this.OTCStlSettleDetailDS.getColumn(fRow, "voy_no"), '0', 4));
        this.OTCStlInvoDetailDS.setColumn(row, "acc_code", this.OTCStlSettleDetailDS.getColumn(fRow, "acc_code"));
    } else {
		this.OTCStlInvoDetailDS.setColumn(row, "voy_no", "0000");
	}
    com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 1, row);
};

this.gd_InvoiceDS_OnRButtonDown = function(obj:nexacro.Grid, e:nexacro.GridMouseEventInfo)
{
    (async () => {
        var cursorRowPos = this.OTCStlInvoDetailDS.rowposition;
        //var cursorCellPos = obj.ClickedCell;
        var cursorCellPos = obj.getCellPos();
        if (e.cell == 4 && cursorCellPos == 4 ) {
            await com.GridCommonCodePopup(this, 'g_Common', obj, cursorRowPos, cursorCellPos, "accountCode", "", "accountCode Search");
            com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, cursorCellPos+1, cursorRowPos);
        } else if(e.cell == 5 && cursorCellPos == 5) {
            await com.GridCommonCodePopup(this, 'g_Common', obj, cursorRowPos, cursorCellPos, "unSettleAccCode", "", "unSettleAccCode Search");
            com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, cursorCellPos+1, cursorRowPos);
        } else if(e.cell == 6 && cursorCellPos == 6) {
            await com.GridCommonCodePopup(this, 'g_Common', obj, cursorRowPos, cursorCellPos, "activeTeamCode", "", "teamCode Search");
            com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, cursorCellPos+1, cursorRowPos);
        } else if(e.cell == 12 && cursorCellPos == 12) {
            //if (OTCStlInvoDetailDS.GetColumn(cursorRowPos, "clct_open_code") == null)    {
            if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(cursorRowPos, "clct_open_code"))) {    // upgrade
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Type"));
                com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, cursorCellPos, cursorRowPos);
                return false;
            }
            if (this.OTCStlInvoDetailDS.getColumn(cursorRowPos, "clct_open_code") == "AP") {
                this.gd_TermAPDS.set_visible(true);
            } else if (this.OTCStlInvoDetailDS.getColumn(cursorRowPos, "clct_open_code") == "AR") {
                this.gd_TermARDS.set_visible(true);
            }
        } else if(e.cell == 15 && cursorCellPos == 15) {
            var accCode = this.OTCStlInvoDetailDS.getColumn(cursorRowPos, "acc_code");
            //if (accCode == null || accCode == "" )    {
            if(com.isEmpty(accCode)) { // upgrade
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Account"));
                com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, 4, cursorRowPos);
                return false;
            }
            if (this.OTCStlInvoDetailDS.getColumn(cursorRowPos, "clct_open_code") != "AP") {
                await com.fnMessageOpenForm(this, "E", "AP 발생의 경우만 선택가능합니다.");
                com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, 3, cursorRowPos);
                return false;
            }
            var param = "";
                param += "parm_acc_code=" + nexacro.wrapQuote(take.nvl(accCode));
                param += " parm_curcy_code=" + nexacro.wrapQuote(take.nvl(this.currencyCol));
            var arrArg = await com.Dialog(this, 'biz::da/daInvoice/BankAccountByCurcyListForm.xfdl', param, 660, 300);
            if (arrArg.length == 0 || arrArg == null)  return false;
            //if(com.length(take.getTrim(this.result)) == 0 || arrArg == null)  return false;        // upgrade
            this.OTCStlInvoDetailDS.setColumn(cursorRowPos, "bank_acc_id", arrArg[0]);
            this.OTCStlInvoDetailDS.setColumn(cursorRowPos, "bank_acc_desc", arrArg[1]);
            com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, cursorCellPos+1, cursorRowPos);
        } else if(e.cell == 19 && cursorCellPos == 19) {
            var result = new Array();
            var param = "";
            var acc_code = this.OTCStlInvoDetailDS.getColumn(cursorRowPos, "acc_code");
            //alert("acc_code : " + acc_code );
            //if (acc_code == null || acc_code == "" )    {
            if(com.isEmpty(acc_code)) { // upgrade
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Account"));
                com.setGridPositionXY(obj, this.OTCStlInvoDetailDS, 4, cursorRowPos);
