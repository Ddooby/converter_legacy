this.OZToPDF = function()
{
	(async () => {
		var stlNo = this.OTCStlHeadDS.getColumn(0, "stl_no");
		var empName = nexacro.getApplication().gdsUserInfo.getColumn(0, "userNm");
		var fileName = this.CCDAprvReqMDS.getColumn(0, "aprv_req_key");
		var param = "STL_NO=" + "'" + stlNo + "'" + common_oz.G_OzSplit;
			param += "EMP_NM=" + empName;
		//AP 존재 여부 체크 (hijang 20200306)
		var apCnt;
			apCnt = await this.getAPCount(stlNo);
		//alert("apCnt : " + apCnt );
		// 지급증빙지 로직 추가 (hijang 20200306)
		var childParm ="";
		if( apCnt > 0 )
		{
			/*
			childParm += "viewer.childcount=1\n";
			childParm += "print.alldocument=true\n";
			childParm += "global.concatpage=true\n";
			childParm += "child1.connection.servlet=http://" + G_OzServer + "/oz/server\n";
			childParm += "child1.connection.reportname=som/EGL/EGLSOMO_V2.ozr\n";
			childParm += "child1.odi.odinames=EGLSOMO_V2\n";
			childParm += "child1.odi.EGLSOMO_V2.pcount=2\n";
			childParm += "child1.odi.EGLSOMO_V2.args1=INVO_NO=" + "'" +  stlNo + "'" +  "\n";
			childParm += "child1.odi.EGLSOMO_V2.args2=ALIAS=" + G_OzSID + "\n";
			*/
			//OZ UPGRADE 210201 GYJ
			childParm += "&oz_param_key=viewer.childcount&oz_param_value=1";
			childParm += "&oz_param_key=print.alldocument&oz_param_value=true";
			childParm += "&oz_param_key=global.concatpage&oz_param_value=true";
			childParm += "&oz_param_key=child1.connection.servlet&oz_param_value=http://" + common_oz.G_OzServer + "/oz/server";
			childParm += "&oz_param_key=child1.connection.reportname&oz_param_value=som/EGL/EGLSOMO_V2.ozr";
			childParm += "&oz_param_key=child1.odi.odinames&oz_param_value=EGLSOMO_V2";
			childParm += "&oz_param_key=child1.odi.EGLSOMO_V2.pcount&oz_param_value=2";
			childParm += "&oz_param_key=child1.odi.EGLSOMO_V2.args1&oz_param_value=INVO_NO=" + "'" +  stlNo + "'";
			childParm += "&oz_param_key=child1.odi.EGLSOMO_V2.args2&oz_param_value=ALIAS=" + common_oz.G_OzSID;
		}

		//var str = OZCreat2Ex_addChild("/som/operSa/2000/OTC034_V1.ozr", "OTC034_V1", param, fileName, "pdf", childParm);
		var str = com.OZCreat3ExAddChild("/som/operSa/2000/OTC034_V1.ozr", "OTC034_V1", param, fileName, "pdf", childParm);        //OZ UPGRADE 210201 GYJ
		// EXOZViewer300.CreateReport(str);
		com.createReportOZ(this, str, null);        //OZ UPGRADE 210201 GYJ
		this.setTimer(common_oz.G_OzTimerID, common_oz.G_OzTimeout);

		this.OTCStlHeadDS.clearData();
		this.OTCStlHeadDS.addRow();
		this.OTCStlHeadDS.set_enableevent(false);
		this.OTCStlHeadDS.setColumn(0, "team_name", nexacro.getApplication().gdsUserInfo.getColumn(0,"teamName"));
		this.OTCStlHeadDS.setColumn(0, "team_code", nexacro.getApplication().gdsUserInfo.getColumn(0,"teamCode"));
		var sysToday = com.somToday(this, 'h');
		// 9시 이전 이면 이전날짜 default
		if(nexacro.toNumber(com.substr(sysToday, 8, 2)) >= 9) {
			sysToday = com.left(sysToday, 8);
		} else {
			sysToday = take.getAddDays(com.left(sysToday, 8), -1);
		}
		this.OTCStlHeadDS.setColumn(0, "posting_date", sysToday);
		this.OTCStlHeadDS.set_enableevent(true);
		this.OTCStlHeadDS.setColumn(0, "curcy_code", "USD");
		await this.fnSetDiffAmt();
	}).call(this);
};

this.fnSetPropBkColorAndEdit = function()
{
    this.gd_SettleDS.set_enableredraw(false);
    for(var row = 0; row < this.OTCStlSettleDetailDS.rowcount; row++) {
        if (this.currencyCol == "USD") {
            this.gd_SettleDS.setCellProperty('body',12,"cssclass","expr:com.drawDetailGridDisableColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',13,"cssclass","expr:com.drawDetailGridBkColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',14,"cssclass","expr:com.drawDetailGridDisableColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',12,"edittype","none");
            this.gd_SettleDS.setCellProperty('body',13,"editfilter","number");  
			this.gd_SettleDS.setCellProperty('body',13,"edittype","mask");
            this.gd_SettleDS.setCellProperty('body',14,"edittype","none");
        } else if (this.currencyCol == "KRW") {
            this.gd_SettleDS.setCellProperty('body',12,"cssclass","expr:com.drawDetailGridDisableColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',13,"cssclass","expr:com.drawDetailGridDisableColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',14,"cssclass","expr:com.drawDetailGridBkColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',12,"edittype","none");
            this.gd_SettleDS.setCellProperty('body',13,"edittype","none");
            this.gd_SettleDS.setCellProperty('body',14,"editfilter","number");  
			this.gd_SettleDS.setCellProperty('body',14,"edittype","mask");
        } else {
            this.gd_SettleDS.setCellProperty('body',12,"cssclass","expr:com.drawDetailGridBkColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',13,"cssclass","expr:com.drawDetailGridDisableColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',14,"cssclass","expr:dom.drawDetailGridDisableColor(currow, '2');");
            this.gd_SettleDS.setCellProperty('body',12,"editfilter","number");  
			this.gd_SettleDS.setCellProperty('body',12,"edittype","mask");
            this.gd_SettleDS.setCellProperty('body',13,"edittype","none");
            this.gd_SettleDS.setCellProperty('body',14,"edittype","none");
        }
    }
    this.gd_SettleDS.set_enableredraw(true);
};

this.fnSetDiffAmt = async function()
{
	var meLocDiffAmt = new nexacro.Decimal(0), meUsdDiffAmt = new nexacro.Decimal(0), meKrwDiffAmt = new nexacro.Decimal(0);
	
	var locDrAmt = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "loc_dr_amt")));
	var locCrAmt = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "loc_cr_amt")));
	locDrAmt.subDecimal(locCrAmt)
    this.me_loc_diff_amt.set_value(locDrAmt);
	
	//120402 GYJ round하지 않으면 .99999 같은 값이 들어가서 Diff금액이 제대로 계산이 안됨.
	var usdDrAmt = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "usd_dr_amt")));
	var usdCrAmt = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "usd_cr_amt")));
	usdDrAmt.subDecimal(usdCrAmt);
	this.me_usd_diff_amt.set_value(nexacro.round(usdDrAmt, 2));
	
    var krwDrAmt = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "krw_dr_amt")));
	var krwCrAmt = new nexacro.Decimal(take.nvl(this.OTCStlHeadDS.getColumn(0, "krw_cr_amt")));
	krwDrAmt.subDecimal(krwCrAmt)
    this.me_krw_diff_amt.set_value(krwDrAmt);
};

this.fnSetDrCrAmt = async function()
{
    //var locCrAmt = 0, krwCrAmt = 0, usdCrAmt = 0, locDrAmt = 0, usdDrAmt = 0, krwDrAmt = 0;
	var locCrAmt = new nexacro.Decimal(0), krwCrAmt = new nexacro.Decimal(0), usdCrAmt = new nexacro.Decimal(0);
	var locDrAmt = new nexacro.Decimal(0), usdDrAmt = new nexacro.Decimal(0), krwDrAmt = new nexacro.Decimal(0);
    for (var row = 0; row < this.OTCStlSettleDetailDS.rowcount; row++)
    {
        row = this.OTCStlSettleDetailDS.findRow("check_item", 1, row);
        if (row == -1) break;
        if (this.OTCStlSettleDetailDS.getColumn(row, "clct_open_code") == "CR") {  // Credit (AR정산)
			var stlLocAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(row, "stl_loc_amt"), 0));
			var stlUsdAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(row, "stl_usd_amt"), 0));
			var stlKrwAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(row, "stl_krw_amt"), 0));
			
			locCrAmt.addDecimal(stlLocAmt);
			usdCrAmt.addDecimal(stlUsdAmt);
			krwCrAmt.addDecimal(stlKrwAmt);
        } else if (this.OTCStlSettleDetailDS.getColumn(row, "clct_open_code") == "DR" ||
            this.OTCStlSettleDetailDS.getColumn(row, "clct_open_code") == "AV" ) {  //  Debit (AP정산, 선수금)
			var stlLocAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(row, "stl_loc_amt"), 0));
			var stlUsdAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(row, "stl_usd_amt"), 0));
			var stlKrwAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(row, "stl_krw_amt"), 0));
			locDrAmt.addDecimal(stlLocAmt);
			usdDrAmt.addDecimal(stlUsdAmt);
			krwDrAmt.addDecimal(stlKrwAmt);
        }
    }

    for (var row2 = 0; row2 < this.OTCStlInvoDetailDS.rowcount; row2++)
    {
        if (this.OTCStlInvoDetailDS.getColumn(row2, "clct_open_code") == "AP" ||
            this.OTCStlInvoDetailDS.getColumn(row2, "clct_open_code") == "GLCR") {  //  AP, GLCR
			var stlLocAmt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(row2, "stl_loc_amt"), 0));
			var stlUsdAmt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(row2, "stl_usd_amt"), 0));
			var stlKrwAmt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(row2, "stl_krw_amt"), 0));
			locCrAmt.addDecimal(stlLocAmt);
			usdCrAmt.addDecimal(stlUsdAmt);
			krwCrAmt.addDecimal(stlKrwAmt);
			
        } else if (this.OTCStlInvoDetailDS.getColumn(row2, "clct_open_code") == "AR" ||
            this.OTCStlInvoDetailDS.getColumn(row2, "clct_open_code") == "GLDR" ) {  // AR, GLDR
			var stlLocAmt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(row2, "stl_loc_amt"), 0));
			var stlUsdAmt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(row2, "stl_usd_amt"), 0));
			var stlKrwAmt = new nexacro.Decimal(take.nvl(this.OTCStlInvoDetailDS.getColumn(row2, "stl_krw_amt"), 0));
			locDrAmt.addDecimal(stlLocAmt);
			usdDrAmt.addDecimal(stlUsdAmt);
			krwDrAmt.addDecimal(stlKrwAmt);
        }
    }
	
    this.OTCStlHeadDS.setColumn(0, "loc_dr_amt", locDrAmt);
    this.OTCStlHeadDS.setColumn(0, "usd_dr_amt", usdDrAmt);
    this.OTCStlHeadDS.setColumn(0, "krw_dr_amt", krwDrAmt);
    this.OTCStlHeadDS.setColumn(0, "loc_cr_amt", locCrAmt);
    this.OTCStlHeadDS.setColumn(0, "usd_cr_amt", usdCrAmt);
    this.OTCStlHeadDS.setColumn(0, "krw_cr_amt", krwCrAmt);
};

this.fnSetStlComparisonRate = async function(nRow)
{
    var openAmt = new nexacro.Decimal(0), stlAmt = new nexacro.Decimal(0), stl_comparison_rate = new nexacro.Decimal(0);
    if (this.currencyCol == "USD") {
        openAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_usd_amt"), 0));
        stlAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_usd_amt"), 0));
    } else if (this.currencyCol == "KRW") {
        openAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_krw_amt"), 0));
        stlAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_krw_amt"), 0));
    } else {
        openAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_loc_amt"), 0));
        stlAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_loc_amt"), 0));
    }
	
    if (openAmt == new nexacro.Decimal(0)) {
        stl_comparison_rate = new nexacro.Decimal(0);
    } else {
        stl_comparison_rate = nexacro.round(stlAmt.div(openAmt), 15);
    }
	
    this.OTCStlSettleDetailDS.setColumn(nRow, "stl_comparison_rate", stl_comparison_rate);
};

this.fnSetSettleAmt = async function(nRow)
{
    var compRate = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_comparison_rate"), 0));
	
	var openLocAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_loc_amt"), 0));
	var openKrwAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_krw_amt"), 0));
	var openUsdAmt = new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_usd_amt"), 0));
    if (this.currencyCol == "USD") {
		this.OTCStlSettleDetailDS.setColumn(nRow, "stl_loc_amt", nexacro.round(openLocAmt.mul(compRate), 2));
        this.OTCStlSettleDetailDS.setColumn(nRow, "stl_krw_amt", Math.trunc(openKrwAmt.mul(compRate), 0));
    } else if (this.currencyCol == "KRW") {
        this.OTCStlSettleDetailDS.setColumn(nRow, "stl_loc_amt", Math.trunc(openLocAmt.mul(compRate), 0));
        this.OTCStlSettleDetailDS.setColumn(nRow, "stl_usd_amt", nexacro.round(openUsdAmt.mul(compRate), 2));
    } else {
        this.OTCStlSettleDetailDS.setColumn(nRow, "stl_usd_amt", nexacro.round(openUsdAmt.mul(compRate), 2));
        this.OTCStlSettleDetailDS.setColumn(nRow, "stl_krw_amt", Math.trunc(openKrwAmt.mul(compRate), 0));
    }
	
    //Loc amt 재설정
    if(this.OTCStlSettleDetailDS.getColumn(nRow, "curcy_code") == "USD") {
        this.OTCStlSettleDetailDS.setColumn(nRow, "stl_loc_amt", new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_usd_amt"), 0)));
    } else if(this.OTCStlSettleDetailDS.getColumn(nRow, "curcy_code") == "KRW") {
        this.OTCStlSettleDetailDS.setColumn(nRow, "stl_loc_amt", new nexacro.Decimal(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_krw_amt"), 0)));
    }
};

this.fnGetExcRate = async function()
{
    var param = "";
        param += "functionGubun=RATE";
        param += " currency_code=" + nexacro.wrapQuote(take.nvl(this.OTCStlHeadDS.getColumn(0, "curcy_code")));
        param += " me_posting_date=" + nexacro.wrapQuote(take.nvl(com.left(com.dateFormatString(this.OTCStlHeadDS.getColumn(0, "posting_date").date), 8)));
        param += " exc_type_code=" + nexacro.wrapQuote("TTA");
    com.syncTransaction(this, "RATE", "SVC_LOC::invoiceNew/RATE.do", "", "TempRateDS=TempRateDS", param, "fnGetExcRateCallback");
};

this.fnGetDueDate = async function(nRow)
{
    //if ( OTCStlInvoDetailDS.GetColumn(nRow, "terms_date") == null ||
    //      OTCStlInvoDetailDS.GetColumn(nRow, "pymt_term") == null )  return false;
    // upgrade
    if ( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "terms_date"))
         || com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "pymt_term")) )  return false;
	
    var param = "";
        param += "functionGubun=DUEDATE";
        param += " posting_date=" + nexacro.wrapQuote(take.nvl(com.dateFormatString(this.OTCStlInvoDetailDS.getColumn(nRow, "terms_date"))));
        param += " pymt_term="    + nexacro.wrapQuote(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "pymt_term")));
		
	this.DueDateDS.clearData();
    com.syncTransaction(this, "DUEDATE", "SVC_LOC::foreignDAInvoice/DUEDATE.do", "", "DueDateDS=DueDateDS", param, "");
	
	if(this.DueDateDS.rowcount > 0) {
		this.OTCStlInvoDetailDS.setColumn(nRow, "due_date", this.DueDateDS.getColumn(0, "code"));
	}
};

