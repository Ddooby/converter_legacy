this.SearchDS_OnColumnChanged = function(obj:nexacro.NormalDataset, e:nexacro.DSColChangeEventInfo)
{
    (async () => {
		/*
        if (e.columnid == "accnt_code1") {
            await com.commCodeInquiry(this, "settleAccountCode", this.ed_accntCode1, this.st_accntName1);
        } else if (e.columnid == "accnt_code2") {
            await com.commCodeInquiry(this, "settleAccountCode", this.ed_accntCode2, this.st_accntName2, null, "Y");
        } else if (e.columnid == "accnt_code3") {
            await com.commCodeInquiry(this, "settleAccountCode", this.ed_accntCode3, this.st_accntName3, null, "Y");
        } else if (e.columnid == "accnt_code4") {
            await com.commCodeInquiry(this, "settleAccountCode", this.ed_accntCode4, this.st_accntName4, null, "Y");
        } else if (e.columnid == "team_code1") {
            await com.commCodeInquiry(this, "activeTeamCode", this.ed_teamCode1, this.st_teamName1, null, "Y");
        } else if (e.columnid == "team_code2") {
            await com.commCodeInquiry(this, "activeTeamCode", this.ed_teamCode2, this.st_teamName2, null, "Y");
        } else if (e.columnid == "team_code3") {
            await com.commCodeInquiry(this, "activeTeamCode", this.ed_teamCode3, this.st_teamName3, null, "Y");
        } else if (e.columnid == "team_code4") {
            await com.commCodeInquiry(this, "activeTeamCode", this.ed_teamCode4, this.st_teamName4, null, "Y");
        } else 
		*/
		if (e.columnid == "gl_acc_code") {
            this.SlipAccMultiSearchDS.clearData();
            //if(varNewValue != "") {
            if(!com.isEmpty(e.newvalue)) { // upgrade
                var rtnFlag = await com.commCodeInquiry(this, "unSettleAccCode", this.ed_glAccCode, this.st_glAccName, null, "Y");
                if (rtnFlag == 1) {
                    var row = this.SlipAccMultiSearchDS.addRow();
                    this.SlipAccMultiSearchDS.setColumn(row, "code", e.newvalue);
                    this.SlipAccMultiSearchDS.setColumn(row, "codename", this.st_glAccName.text);
                }
            } else {
                this.SearchDS.setColumn(0, "gl_acc_name", "");
            }
        } else if (e.columnid == "from_date") {
            if (!com.isValidDate(this.me_fromDate)) this.me_fromDate.setFocus();
        } else if (e.columnid == "to_date") {
            if (! com.isValidDate(this.me_toDate)) this.me_toDate.setFocus();
        //120726 GYJ
        } else if (e.columnid == "me_fromDueDate") {
            if (! com.isValidDate(this.me_fromDueDate)) this.me_fromDueDate.setFocus();
        } else if (e.columnid == "me_toDueDate") {
            if (! com.isValidDate(this.me_toDueDate)) this.me_toDueDate.setFocus();
        }
    }).call(this);
};

