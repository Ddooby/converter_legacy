 * 4 사용자 FUNCTION 영역
 ********************************************************/

this.fnValidationCheck = async function()
{
	var postingDate = com.dateFormatString(this.OTCStlHeadDS.getColumn(0, "posting_date"));
	//if (postingDate == null) {
	if (com.isEmpty(postingDate)) { // upgrade
		await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "GL Date"));
		this.me_postingDate.setFocus();
		return false;
	}
	if (!com.isValidDate(this.me_postingDate)) {
		this.me_postingDate.setFocus();
		return false;
	}
	if (com.left(postingDate, 8) > this.somToday) {
		await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_2100.VAL_0056", "input", "GL Date"));
		this.me_postingDate.setFocus();
		return false;
	}
	//ryu 2009.11.30
	if (await com.monthCloseCheck(this, 'SOMO', postingDate) == false) {
		this.me_postingDate.setFocus();
		return false;
	}
	//if (OTCStlHeadDS.getColumn(0, "curcy_code") == null) {
	if (com.isEmpty(this.OTCStlHeadDS.getColumn(0, "curcy_code"))) {    // upgrade
		await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Currency"));
		this.cb_currency.setFocus();
		return false;
	}
	if (this.OTCStlSettleDetailDS.findRow("check_item", 1) == -1 ) {
		await com.fnMessageOpenForm(this, "E", "Domain.msg.UCG_2001.VAL_0017");
		return false;
	}
	// SettleDS
	if (!await this.fnSettleDSCheck()) return false;
	// InvoiceDS
	if (!await this.fnInvoiceDSCheck()) return false;
	//---------------------------------------------------------------------------------------
	// [ 계산 오류 해결 ] - hijang ( 20110926 )
	// 여러line에 대해서 정산처리 할때,,
	// diff_amt 값에 이상한 dummy 데이터가 붙는 현상 발생함 ( ex. -0.0000005 )
	// -> Mi-platform 버그가 아닌지..
	// 하여튼, 이 문제를 해결하기 위해서 round 처리하여 문제 해결함.
	//  ( 현재 데이터는 소수점 2자리가 max 이므로,, 강제로 2자리에서 끊어버림.. )
	//---------------------------------------------------------------------------------------
	/*
	this.me_loc_diff_amt.set_value(Math.trunc(new nexacro.Decimal(take.nvl(this.me_loc_diff_amt.value)), 2));
	this.me_usd_diff_amt.set_value(Math.trunc(new nexacro.Decimal(take.nvl(this.me_usd_diff_amt.value)), 2));
	this.me_krw_diff_amt.set_value(Math.trunc(new nexacro.Decimal(take.nvl(this.me_krw_diff_amt.value)), 2));
	*/
	this.me_loc_diff_amt.set_value(nexacro.floor(new nexacro.Decimal(take.nvl(this.me_loc_diff_amt.value)), 3));
	this.me_usd_diff_amt.set_value(nexacro.floor(new nexacro.Decimal(take.nvl(this.me_usd_diff_amt.value)), 3));
	this.me_krw_diff_amt.set_value(nexacro.floor(new nexacro.Decimal(take.nvl(this.me_krw_diff_amt.value)), 3));
	
	var curcyCnt = this.OTCStlSettleDetailDS.getCaseCount("check_item == 1 && curcy_code != '" + this.currencyCol + "'");
	if(curcyCnt == 0) {   // Master와 동일한 화폐만으로 발생, 정산이 이뤄진 경우 Loc 금액의 diff도 체크
		if(nexacro.toNumber(this.me_loc_diff_amt.value) != 0) {
			await com.fnMessageOpenForm(this, "E", "차변, 대변의 Diff 금액은 0 이어야 합니다.");
			return false;
		}
	}
	if(nexacro.toNumber(take.nvl(this.me_usd_diff_amt.value)) != 0 || nexacro.toNumber(take.nvl(this.me_krw_diff_amt.value)) != 0) {
		await com.fnMessageOpenForm(this, "E", "차변, 대변의 Diff 금액(USD, KRW)은 0 이어야 합니다. \n[환차손익 자동생성]으로 Diff를 조정해 주세요.");
		return false;
	}
	/*
	if((currencyCol == "KRW" && toNumber(me_krw_diff_amt.Value) != 0 ) ||
	(currencyCol == "USD" && toNumber(me_usd_diff_amt.Value) != 0 ) ||
	(currencyCol != "KRW" && currencyCol != "USD" && toNumber(me_loc_diff_amt.Value) != 0 )) {
		g_fnMessageOpenForm("E", "Domain.msg.UCG_1800.VAL_0004");
		return false;
	}
	*/      //RYU 2010.04.12
	// 110425 GYJ- 국외거래처인 경우만 email입력 가능하게 함
	for (var nRow = 0; nRow < this.OTCStlInvoDetailDS.rowcount; nRow++) {
		if(this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AP" ) {
			/*
			// payment hold 체크시 ?
			// -> '법원허가번호' 등록여부체크 & 한도체크 는 할 필요없다. ( 20140502 - hijang )
			if( OTCStlInvoDetailDS.Getcolumn(nRow,"pymt_hold_flag") <> 1 ) {    // 미체크시( null or 0 )
				// 1) AP 5000만원 이상일때, 법원허가번호 등록여부 체크 (20140307) hijang
				if( OTCStlInvoDetailDS.Getcolumn(nRow,"stl_krw_amt") >= 50000000 ){
					if( g_isEmpty(OTCStlInvoDetailDS.Getcolumn(nRow,"court_admit_no")) ){
						g_fnMessageOpenForm("E", "송금액이 5천만 원 이상일 경우 반드시 해당 송금에 대한\n법원/포괄허가번호를 지정해야 합니다.\n법원/포괄허가가 불가피하게 늦어지는 경우에는 임시번호를 생성하여 \n지정해야 합니다.\n");
						//g_setGridPositionXY(gd_InvoiceDS, OTCStlInvoDetailDS, 23, nRow);
						g_setGridPosition(gd_InvoiceDS, nRow, 'court_admit_no');
						return false;
					}
				}
				// 2) 해당 법원/포괄허가번호의 한도금액 체크.. (20140502) hijang
				if( !g_isEmpty(OTCStlInvoDetailDS.Getcolumn(nRow,"court_admit_no")) ){
					var ret_value = g_GetCourtPermitBudgetLimitCheck2(OTCStlInvoDetailDS.Getcolumn(nRow,"court_admit_no"),
														OTCStlInvoDetailDS.Getcolumn(nRow,"stl_krw_amt"),
														OTCStlInvoDetailDS.Getcolumn(nRow,"court_flag"));
					if( substr(ret_value,0,4) == "FAIL"){
							g_fnMessageOpenForm("E", replace(replace("Domain.msg.common.VAL_0128","input",OTCStlInvoDetailDS.Getcolumn(nRow,"court_admit_no")), "amt",substr(ret_value,4)) );
							g_setGridPosition(gd_InvoiceDS, nRow, 'court_admit_no');
							return;
					}
				}
			}
			*/
			// 3) 계좌번호 필수입력 - hijang (20140418)
			//    단, gl_date 가 2014.05.01 이후에만 체크,,
			if( postingDate >= "20140501" ) {
				if( this.OTCStlInvoDetailDS.getColumn(nRow,"pymt_hold_flag") != 1 ) {    // 미체크시( null or 0 )
					if(com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow,"bank_acc_id"))) {
						await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Bank Account"));
						com.setGridPosition(this.gd_InvoiceDS, nRow, 'bank_acc_id');
						return false;
					} else {
						// 송금 제한 국가 - 체크로직 ( HIJANG 20160621 )
						var enable_flag = await com.EnableAccoutNumberCheck(this, this.OTCStlInvoDetailDS.getColumn(nRow,"bank_acc_id"));
						//alert("enable_flag : " + enable_flag );
						if( enable_flag == "N") {        // 송금제한국가
							await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0137");
							return false;
						} else if( enable_flag == "P") {    // 제한적 송금가능국가
							var rtnVal = await com.fnMessageOpenWideForm(this, "C", "Domain.msg.common.VAL_0138");
							if( rtnVal == "CANCEL" ) {
								return false;
							}
						} else if( enable_flag == "E") {    // 국가코드없음
							await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0139");
							return false;
						}
					}
				}
			}
		}
		//------------------------------------------------------------------------------------------------------------------------
		// 일반관리비 은행수수료('630601') -> 고정비 은행수수료('540203') 으로 계정 변경 관련 (20160906 HIJANG)
		//------------------------------------------------------------------------------------------------------------------------
		if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "gl_acc_code"))) {    // upgrade
			var glAccCode = this.OTCStlInvoDetailDS.getColumn(nRow, "gl_acc_code");
			//alert("glAccCode : " + glAccCode);
			if( glAccCode == "540203" ) {
				if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "team_code")) ) {
					var enable_flag = await com.isSalesTeamCodeCheck(this, this.OTCStlInvoDetailDS.getColumn(nRow, "team_code"));
					//alert("enable_flag : " +enable_flag);
					if( enable_flag == "N") {  // 비영업팀
						await com.fnMessageOpenForm(this, "E", "은행수수료(540203) 계정은 영업팀만 선택하실 수 있습니다.\n확인 바랍니다.");
						this.OTCStlInvoDetailDS.setColumn(nRow, "team_code","");     // 팀코드  clear
						com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 6, nRow);
						return false;
					}
				}
			}
		}
		//if(OTCStlInvoDetailDS.GetColumn(nRow,"email_1") != null && OTCStlInvoDetailDS.GetColumn(nRow,"email_1") != "") {
		if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "email_1"))) {    // upgrade
			var acc_code = this.OTCStlInvoDetailDS.getColumn(nRow, "acc_code");
			var arrArg = await com.getCommCode(this, "accountCodeAll", acc_code, "");
			if (arrArg == 0 || com.length(take.getTrim(arrArg)) == 0) return; //  upgrade 박진석
			if (arrArg[3] == "KR") {
				await com.fnMessageOpenForm(this, "E","국내거래처는 e-mail 주소를 입력하 실 수 없습니다.");
				com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 19, nRow);
				return false;
			}
		}
		//if(trim(OTCStlInvoDetailDS.GetColumn(nRow,"email_2")) != null && trim(OTCStlInvoDetailDS.GetColumn(nRow,"email_2")) != "") {
		if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "email_2"))) {    // upgrade
			this.acc_code = this.OTCStlInvoDetailDS.getColumn(nRow, "acc_code");
			var arrArg = await com.getCommCode(this, "accountCodeAll", acc_code, "");
			if (arrArg == 0 || com.length(take.getTrim(arrArg)) == 0) return; //  upgrade 박진석
			if (arrArg[3] == "KR") {
				await com.fnMessageOpenForm(this, "E","국내거래처는 e-mail 주소를 입력하 실 수 없습니다.");
				com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 20, nRow);
				return false;
			}
		}
		//if(trim(OTCStlInvoDetailDS.GetColumn(nRow,"email_3")) != null && trim(OTCStlInvoDetailDS.GetColumn(nRow,"email_3")) != "") {
		if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "email_3"))) {    // upgrade
			var acc_code = this.OTCStlInvoDetailDS.getColumn(nRow, "acc_code");
			var arrArg = await com.getCommCode(this, "accountCodeAll", acc_code, "");
			if (arrArg == 0 || com.length(take.getTrim(arrArg)) == 0) return; //  upgrade 박진석
			if (arrArg[3] == "KR") {
				await com.fnMessageOpenForm(this, "E","국내거래처는 e-mail 주소를 입력하 실 수 없습니다.");
				com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 21, nRow);
				return false;
			}
		}
		//if(trim(OTCStlInvoDetailDS.GetColumn(nRow,"email_4")) != null && trim(OTCStlInvoDetailDS.GetColumn(nRow,"email_4")) != "") {
		if( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "email_4"))) {    // upgrade
			var acc_code = this.OTCStlInvoDetailDS.getColumn(nRow, "acc_code");
			var arrArg = await com.getCommCode(this, "accountCodeAll", acc_code, "");
			if (arrArg == 0 || com.length(take.getTrim(arrArg)) == 0) return; //  upgrade 박진석
			if (arrArg[3] == "KR") {
				await com.fnMessageOpenForm(this, "E","국내거래처는 e-mail 주소를 입력하 실 수 없습니다.");
				com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 22, nRow);
				return false;
			}
		}
		//AP, AR이 하나라도 발생하는데 중복 거래처면 error 130522 GYJ
		if (this.OTCStlInvoDetailDS.getColumn(nRow,"clct_open_code") == 'AP' || this.OTCStlInvoDetailDS.getColumn(nRow,"clct_open_code") == 'AR') {
			var arrArg = await com.getAllCommCode(this, "accountCodeAll", this.OTCStlInvoDetailDS.getColumn(nRow, "acc_code"), null);
			var acc_dupFlag = arrArg[9];
			var activeFlag = arrArg[5];
			//Active인데 dupe flag = 'y' 인 경우 error
			if (activeFlag == 'ACTIVE') {
				if (acc_dupFlag == 'Y') {
					var result = await com.fnMessageOpenForm(this, "C", "중복으로 사용이 제한된 거래처로 아래의 거래처를 사용 하시기 바랍니다."
										+"\n\n("+arrArg[10]+") "+arrArg[11]
										+"\n\n 해당 거래처를 사용 하시겠습니까.?");
					if (result == 'YES') {
						this.OTCStlInvoDetailDS.setColumn(nRow, "acc_code", arrArg[10]);
						com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, nRow);
					} else {
						this.OTCStlInvoDetailDS.setColumn(nRow, "acc_code", "");
						com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, nRow);
					}
					return false;
				}
			} else {
				//Inactive인 경우 정산이든 발생이든 전표 발생 불가.
				await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0075");
				com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, nRow);
				return false;
			}
		}
		//140818 GYJ (-)미결 발생 불가
		if(this.OTCStlInvoDetailDS.getColumn(nRow,"clct_open_code") == 'AP' ||
			this.OTCStlInvoDetailDS.getColumn(nRow,"clct_open_code") == 'AR') {
			if(nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow,"stl_loc_amt"))) < 0) {
				await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0087", "input", "Loc Amount"));
				com.setGridPosition(this.gd_InvoiceDS, nRow, 'stl_loc_amt');
				return false;
			}
		}
	}
	return true;
};

this.fnSettleDSCheck = async function()
{
    var colIndex = 0;
    if (this.currencyCol == "KRW") {
        colIndex = 14;
    } else if (this.currencyCol == "USD") {
        colIndex = 13;
    } else {
        colIndex = 12;
    }
    for(var nRow = 0; nRow < this.OTCStlSettleDetailDS.rowcount; nRow++) {
        nRow = this.OTCStlSettleDetailDS.findRow("check_item", 1, nRow);
        if (nRow == -1) break;
        if (nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_loc_amt"))) == 0 ||
            nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_usd_amt"))) == 0 ||
            nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_krw_amt"))) == 0 ) {
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_2100.VAL_0013", "Item", "Clear Amount"));
            com.setGridPositionXY(this.gd_SettleDS, this.OTCStlSettleDetailDS, colIndex, nRow);
            return false;
        }
        if (nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_usd_amt"))) < 0  &&
            (nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_usd_amt"))) != nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_usd_amt"))))) {
            await com.fnMessageOpenForm(this, "E", "minus(-) 금액은 부분 정산이 불가합니다.");
            com.setGridPositionXY(this.gd_SettleDS, this.OTCStlSettleDetailDS, colIndex, nRow);
            return false;
        }
        if (nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "stl_usd_amt"))) > nexacro.toNumber(take.nvl(this.OTCStlSettleDetailDS.getColumn(nRow, "open_usd_amt")))) {
            await com.fnMessageOpenForm(this, "E", "Domain.msg.UCG_2100.VAL_0043");
            com.setGridPositionXY(this.gd_SettleDS, this.OTCStlSettleDetailDS, colIndex, nRow);
            return false;
        }
        if (nexacro.toNumber(com.dateFormatString(this.OTCStlSettleDetailDS.getColumn(nRow, "src_posting_date"))) > nexacro.toNumber(com.dateFormatString(this.OTCStlHeadDS.getColumn(0, "posting_date")))) {
            await com.fnMessageOpenForm(this, "E", "Domain.msg.UCG_2100.VAL_0054");
            this.me_postingDate.setFocus();
            return false;
        }
        //해외대리점 계약서 존재여부 CHECK 200813 GYJ (정산 대상이 “대리점선급금(110917)” 계정일 때 한정)
        /*
        if( OTCStlSettleDetailDS.GetColumn(nRow, "gl_acc_code") == '110917'){
            var a = g_getForeignAgentCntr(OTCStlSettleDetailDS.GetColumn(nRow, "acc_code"));
            if( a == 0 ){
                g_fnMessageOpenForm("E", "대리계약서 미체결 대리점으로, 발란스 일괄 정산 불가");
                g_setGridPositionXY(gd_SettleDS, OTCStlSettleDetailDS, colIndex, nRow);
                return false;
            }
        }
        */        //TOBE
    }
    return true;
};

this.fnInvoiceDSCheck = async function()
{
    var vslCode = "";
    var voyNo = null;
    var glAccCode = "";
    for (var nRow = 0; nRow < this.OTCStlInvoDetailDS.rowcount; nRow++) {
        vslCode = this.OTCStlInvoDetailDS.getColumn(nRow, "vsl_code");
        voyNo = this.OTCStlInvoDetailDS.getColumn(nRow, "voy_no");
        glAccCode = this.OTCStlInvoDetailDS.getColumn(nRow, "gl_acc_code");
        //if (OTCStlInvoDetailDS.GetColumn(nRow, "vsl_code") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "vsl_code")) == "") {
        if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "vsl_code"))) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Vsl Code"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 1, nRow);
            return false;
        }
        //if (OTCStlInvoDetailDS.GetColumn(nRow, "voy_no") == null) {
        if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "voy_no"))) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Voy No"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 2, nRow);
            return false;
        }
        if (com.isValidVslVoy(this, vslCode, voyNo) == false ) {
            await com.fnMessageOpenForm(this, "E", "Domain.msg.UCG_1200.VAL_0095");
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 1, nRow);
            return false;
        }
        //if (OTCStlInvoDetailDS.GetColumn(nRow, "clct_open_code") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "clct_open_code")) == "") {
        if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code"))) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Type"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS,3, nRow);
            return false;
        }
        //if (OTCStlInvoDetailDS.GetColumn(nRow, "acc_code") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "acc_code")) == "") {
        if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "acc_code"))) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Account"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, nRow);
            return false;
        }
        // Add 하면서 Account를 자동 세팅하면서 gd_InvoiceDS_OnCellPosChanged 가 실행 안되므로 한번더 체크해줌
        if(com.validateCommCode(this, "accountCode", this.OTCStlInvoDetailDS.getColumn(nRow, "acc_code")) == false) {
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_5200.VAL_0002", "input", "Account"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 4, nRow);
            return false;
        }
        //if (OTCStlInvoDetailDS.GetColumn(nRow, "gl_acc_code") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "gl_acc_code")) == "") {
        if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "gl_acc_code"))) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "GL Accnt"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 5, nRow);
            return false;
        }
        // RYU : AP는 egl_account_v.attribute30 = 'L' 이고 AR은 'A' 이나 부채(L)계정이어도 AR에서 관리하는 예외 항목도 있다함 (FCM에 문의 필요)
        //       아래로직의 계정 시작 문자 1, 2로 비교하는것은 100% 정확한 것은 아니나 우리가 할려는 것은 이정도로로 cover가 됨.
        if ((this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AP" && com.left(glAccCode, 1) != "2") ||
                   (this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AR" && com.left(glAccCode, 1) != "1") ||
                   //(OTCStlInvoDetailDS.GetColumn(nRow, "clct_open_code") == "GLDR" && (glAccCode != "630601" && glAccCode != "800101" && glAccCode != "830101")) ||
                   (this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "GLDR" && (glAccCode != "540203" && glAccCode != "800101" && glAccCode != "830101")) ||        // 630601 제거 -> 540203 추가 (HIJANG 20160906)
                   (this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "GLCR" && (glAccCode != "730101" && glAccCode != "760101")))  {
            await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0022");
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 5, nRow);
            return false;
        }
        //if (OTCStlInvoDetailDS.GetColumn(nRow, "team_code") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "team_code")) == "") {
        if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "team_code"))) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Team"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 6, nRow);
            return false;
        }
        //if (OTCStlInvoDetailDS.GetColumn(nRow, "curcy_code") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "curcy_code")) == "") {
        if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "curcy_code"))) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Currency"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 7, nRow);
            return false;
        }
        if ((glAccCode != "730101" && glAccCode != "800101") &&
                 //(OTCStlInvoDetailDS.GetColumn(nRow, "stl_loc_amt") == null || OTCStlInvoDetailDS.GetColumn(nRow, "stl_loc_amt") == 0)) {
                 (com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_loc_amt")) || this.OTCStlInvoDetailDS.getColumn(nRow, "stl_loc_amt") == 0)) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input",  "LOC Amt"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 8, nRow);
            return false;
        }
        if (com.left(this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code"), 2) == "GL" &&
                   nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_loc_amt"))) < 0) {
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_1800.VAL_0012", "item", "LOC Amt"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 8, nRow);
            return false;
        }
        if (com.left(this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code"), 2) == "GL" &&
                   nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_usd_amt"))) < 0) {
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_1800.VAL_0012", "item", "USD Amt"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 9, nRow);
            return false;
        }
        if (com.left(this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code"), 2) == "GL" &&
                   nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_krw_amt"))) < 0) {
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_1800.VAL_0012", "item", "KRW Amt"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 10, nRow);
            return false;
        }
        if ((glAccCode == "760101" || glAccCode == "830101") &&
                   (nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_loc_amt"))) > 100)) {
            //g_fnMessageOpenForm("E", "잡이익, 잡손실은 100$ 이하여야 합니다.");
            await com.fnMessageOpenForm(this, "E", "잡이익, 잡손실은 (LOC_AMT) 100 이하여야 합니다.");
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 8, nRow);
            return false;
        }
        if ((glAccCode != "730101" && glAccCode != "800101") &&
                   //(OTCStlInvoDetailDS.GetColumn(nRow, "stl_usd_amt") == null || OTCStlInvoDetailDS.GetColumn(nRow, "stl_usd_amt") == 0)) {
                   (com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_usd_amt")) || this.OTCStlInvoDetailDS.getColumn(nRow, "stl_usd_amt") == 0)) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "USD Amt"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 9, nRow);
            return false;
        }
        if ((glAccCode != "730101" && glAccCode != "800101") &&
                   //(OTCStlInvoDetailDS.GetColumn(nRow, "stl_krw_amt") == null || OTCStlInvoDetailDS.GetColumn(nRow, "stl_krw_amt") == 0)) {
                   (com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_krw_amt")) || this.OTCStlInvoDetailDS.getColumn(nRow, "stl_krw_amt") == 0)) {    // upgrade
            await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "KRW Amt"));
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 10, nRow);
            return false;
        }
        if(this.currencyCol == "USD" &&
                    nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_loc_amt"))) != nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_usd_amt")))) {
            await com.fnMessageOpenForm(this, "E", "LOC, USD 금액은 같아야 합니다.");
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 8, nRow);
            return false;
        }
        if(this.currencyCol == "KRW" &&
           nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_loc_amt"))) != nexacro.toNumber(take.nvl(this.OTCStlInvoDetailDS.getColumn(nRow, "stl_krw_amt")))) {
            await com.fnMessageOpenForm(this, "E", "LOC, KRW 금액은 같아야 합니다.");
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 8, nRow);
            return false;
        }
        if (this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AP" ||
            this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AR") { // AP, AR에 대해서만 terms_date ~ due_date 까지 필수 체크
            //if (OTCStlInvoDetailDS.GetColumn(nRow, "terms_date") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "terms_date")) == "") {
            if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "terms_date"))) {    // upgrade
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Terms Date"));
                com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 11, nRow);
                return false;
            }
            //if (OTCStlInvoDetailDS.GetColumn(nRow, "pymt_term") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "pymt_term")) == "") {
            if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "pymt_term"))) {    // upgrade
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Term"));
                com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 12, nRow);
                return false;
            }
            //if (OTCStlInvoDetailDS.GetColumn(nRow, "due_date") == null || Trim(OTCStlInvoDetailDS.GetColumn(nRow, "due_date")) == "") {
            if( com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "due_date"))) {    // upgrade
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.common.VAL_0001", "input", "Due Date"));
                com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 13, nRow);
                return false;
            }
            if (com.left(this.OTCStlInvoDetailDS.getColumn(nRow, "due_date"), 8) < this.somToday) {
                await com.fnMessageOpenForm(this, "E", "Domain.msg.UCG_1700.VAL_0045");
                com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 11, nRow);
                return false;
            }
            if(this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AP" &&
                this.PaymentTermAPDS.findRow("code", this.OTCStlInvoDetailDS.getColumn(nRow, "pymt_term")) == -1) {
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_2100.VAL_0007", "code", "Payment Term(AP)"));
                return false;
            }
            if(this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AR" &&
                this.PaymentTermARDS.findRow("code", this.OTCStlInvoDetailDS.getColumn(nRow, "pymt_term")) == -1) {
                await com.fnMessageOpenForm(this, "E", com.replace("Domain.msg.UCG_2100.VAL_0007", "code", "Payment Term(AR)"));
                return false;
            }
        }
        //if( (OTCStlInvoDetailDS.GetColumn(nRow, "from_date") != null && OTCStlInvoDetailDS.GetColumn(nRow, "to_date") != null ) &&
        if( ( !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "from_date")) && !com.isEmpty(this.OTCStlInvoDetailDS.getColumn(nRow, "to_date")) ) &&
                   (nexacro.toNumber(this.OTCStlInvoDetailDS.getColumn(nRow, "from_date")) > nexacro.toNumber(this.OTCStlInvoDetailDS.getColumn(nRow, "to_date"))) ) {
            await com.fnMessageOpenForm(this, "E", "Domain.msg.common.VAL_0045");
            com.setGridPositionXY(this.gd_InvoiceDS, this.OTCStlInvoDetailDS, 16, nRow);
            return false;
        }
    }
    return true;
};

this.fnPymtSetting = function()
{
    // 현업 확인 필요..  RYU
    for (var nRow = 0; nRow < this.OTCStlInvoDetailDS.rowcount; nRow++) {
        if (this.OTCStlInvoDetailDS.getColumn(nRow, "clct_open_code") == "AP") {
            this.OTCStlInvoDetailDS.setColumn(nRow, "pymt_meth", "CHECK");
        } else {
            this.OTCStlInvoDetailDS.setColumn(nRow, "pymt_meth", "");
        }
    }
};

this.fnPreReceiptAccYn = async function()
{
    var gl_acc_code ="";
    var src_posting_date = "";
    for(var nRow=0; nRow<this.OTCStlSettleDetailDS.rowcount; nRow++)
    {
        gl_acc_code = this.OTCStlSettleDetailDS.getColumn(nRow, "gl_acc_code");
        src_posting_date = com.dateFormatString(this.OTCStlSettleDetailDS.getColumn(nRow, "src_posting_date"));
        if( gl_acc_code == "210701" ) {
            //법정관리로 인한 중간마감 때문에 선수금 정산 가능토록 임시 수정함 130620
            if (com.substr(src_posting_date,0,6) == '201306') {
                src_posting_date = '20130618';
            } else {
                src_posting_date = src_posting_date;
            }
            //--------------------------------------------------------------------------
            // 1) 마감 여부 체크,,
            if (await com.isMonthCloseCheck('SOMO', src_posting_date) == false) {
                return true;    // 선수금 이면서,, 마감된건,,
            } else {
                return false;
            }
        }
    }
    return false;
};

this.fnRequestTransaction = function()
{
	//this.CCDAprvReqMDS.clearData();
	//this.OTCStlHeadDS.clearData();

    var param = "functionGubun='SETOFF_Request'";
        param += " stl_no=" + nexacro.wrapQuote(take.nvl(this.OTCStlHeadDS.getColumn(0, "stl_no")));
    com.syncTransaction(this, "save", "SVC_LOC::brokerageIncomeSettlement/SETOFF_Request.do", "", "CCDAprvReqMDS=CCDAprvReqMDS OTCStlHeadDS=OTCStlHeadDS", param, "fnRequestCallback");
};

