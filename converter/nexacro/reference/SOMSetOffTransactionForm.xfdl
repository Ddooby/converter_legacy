                <Cell col="10" textAlign="right" text="bind:stl_krw_amt" displaytype="mask" edittype="expr:com.iif((gl_acc_code == &quot;800101&quot; || gl_acc_code == &quot;730101&quot;) &amp;&amp; curcy_code != &quot;KRW&quot; , &quot;mask&quot;, &quot;none&quot;)" maskeditformat="#,##0"/>
                <Cell col="11" text="bind:terms_date" displaytype="date" edittype="expr:com.iif(clct_open_code == &quot;AP&quot; || clct_open_code == &quot;AR&quot; , &quot;date&quot;, &quot;none&quot;)" maskeditformat="yyyy-MM-dd" textAlign="center" calendardisplaynulltype="none" calendardateformat="yyyy-MM-dd" calendardisplayinvalidtype="none"/>
