    {"from": "import com.tobesoft.platform.PlatformResponse;\n", "to": ""},
    {"from": "import com.tobesoft.platform.data.Dataset;\n", "to": ""},
    {"from": "import com.tobesoft.platform.data.DatasetList;\n", "to": ""},
    {"from": "import com.tobesoft.platform.data.VariableList;\n", "to": ""},
    {"from": "import com.stx.som.miplatform.dataset.DataSetManager;\n", "to": "import com.pan.som.common.utility.DataSetManager;\n"},
    {"from": "import com.stx.som.common.exception.STXException;\n", "to": ""},
    {"from": "import com.stx.som.common.servicefactory.ServiceObjFactory;\n", "to": ""},
    {"from": "import com.stx.som.common.servlet.GeneralServlet;\n", "to": ""},
    {"from": "import com.stx.som.common.utility.UserBean;\n", "to": ""},
    {"from": "import com.stx.som.common.utility.Formatter;\n", "to": "import com.pan.som.common.utility.Formatter;\n"},
